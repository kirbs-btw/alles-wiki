---
interface Props {
  class?: string;
  variant?: 'light' | 'dark';
}
const { class: className = '', variant = 'dark' } = Astro.props;
const textColor = variant === 'light' ? 'text-white' : 'text-zinc-900';
---

<span class={`inline-flex items-center gap-2 ${className}`}>
  <svg width="30" height="30" viewBox="0 0 32 32" fill="none" aria-hidden="true">
    <rect width="32" height="32" rx="7" fill="#2563eb"></rect>
    <path
      d="M16 9c-2-1.4-4.2-1.6-6.5-1.2-.3.05-.5.3-.5.6V21c0 .35.32.6.66.55C11.7 21.2 14 21.4 16 23M16 9c2-1.4 4.2-1.6 6.5-1.2.3.05.5.3.5.6V21c0 .35-.32.6-.66.55C20.3 21.2 18 21.4 16 23M16 9v14"
      stroke="white"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
  <span class={`text-lg font-extrabold tracking-tight ${textColor}`}>AllesWiki</span>
</span>
