---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { articleLd, breadcrumbLd } from '../../lib/schema';

export async function getStaticPaths() {
  const entries = await getCollection('wissen', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const cat = getCategory(entry.data.category)!;
const path = `/wissen/${entry.id}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Wissen', href: '/wissen' },
  { name: cat.name, href: `/wissen#${cat.slug}` },
  { name: entry.data.title, href: path },
];

// Verwandte Rechner: nur tatsächlich existierende Slugs verlinken.
const relatedTools = (entry.data.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

// Cross-Links: passende Anleitungen + weitere Artikel derselben Kategorie.
const moreHowto = (await getCollection('howto', ({ data }) => !data.draft && data.category === entry.data.category)).slice(0, 3);
const moreWissen = (await getCollection('wissen', ({ data }) => !data.draft && data.category === entry.data.category))
  .filter((e) => e.id !== entry.id)
  .slice(0, 3);

const ld: object[] = [
  articleLd({
    title: entry.data.title,
    description: entry.data.description,
    path,
    updated: entry.data.updated,
    keywords: entry.data.keywords,
  }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  path={path}
  ogType="article"
  jsonLd={ld}
>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name}</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">
        {entry.data.title}
      </h1>
      <p class="mt-2 text-lg text-zinc-600">{entry.data.description}</p>
      <p class="mt-1 text-xs text-zinc-500">Aktualisiert: {entry.data.updated}</p>
    </header>

    <article class="prose-werkbank mt-10 max-w-none">
      <Content />
    </article>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <p class="mt-1 text-sm text-zinc-600">
            Direkt ausrechnen statt nur nachlesen:
          </p>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a
                href={`/rechner/${t.slug}/`}
                class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md"
              >
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      (moreHowto.length > 0 || moreWissen.length > 0) && (
        <section class="mt-12">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Mehr aus {cat.name}</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {moreHowto.map((e) => (
              <a href={`/how-to/${e.id}/`} class="block rounded-lg border border-zinc-200 bg-white px-4 py-3 text-sm transition hover:border-brand-300 hover:shadow-md">
                <span class="text-xs font-semibold text-brand-700">Anleitung</span>
                <span class="mt-0.5 block font-medium text-zinc-800">{e.data.title}</span>
              </a>
            ))}
            {moreWissen.map((e) => (
              <a href={`/wissen/${e.id}/`} class="block rounded-lg border border-zinc-200 bg-white px-4 py-3 text-sm transition hover:border-brand-300 hover:shadow-md">
                <span class="text-xs font-semibold text-brand-700">Wissen</span>
                <span class="mt-0.5 block font-medium text-zinc-800">{e.data.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
