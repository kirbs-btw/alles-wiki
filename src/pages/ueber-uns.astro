---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
import { TOTAL_TOOLS } from '../lib/registry';
import { CATEGORIES } from '../lib/categories';
---

<BaseLayout
  title="Über uns"
  description={`Was ist ${SITE.name}? Kostenlose Rechner, Wissen und How-to zu allen Alltagsthemen in Deutschland.`}
  path="/ueber-uns"
>
  <div class="prose-werkbank mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-extrabold tracking-tight">Über {SITE.name}</h1>
    <p>
      {SITE.name} ist ein wachsendes Nachschlagewerk für den deutschen Alltag: kostenlose Rechner,
      verständliches Wissen und praktische Anleitungen zu allen großen Themen – aktuell {CATEGORIES.length}
      Bereiche von Finanzen über Gesundheit bis Recht, gestartet mit {TOTAL_TOOLS} Rechnern und stetig wachsend.
    </p>
    <h2>Unser Plan</h2>
    <ul>
      <li><strong>1. Rechner</strong> zu jedem Alltagsthema – der Anfang.</li>
      <li><strong>2. Wissen</strong> – verständliche Artikel, die die Themen erklären.</li>
      <li><strong>3. How-to</strong> – Schritt-für-Schritt-Anleitungen.</li>
    </ul>
    <h2>Wofür wir stehen</h2>
    <ul>
      <li><strong>Verständlich:</strong> klare Sprache, nachvollziehbare Formeln.</li>
      <li><strong>Schnell:</strong> statische Seiten, Ergebnisse rechnen live im Browser.</li>
      <li><strong>Privat:</strong> keine Anmeldung, Eingaben verlassen dein Gerät nicht.</li>
    </ul>
    <h2>Hinweis</h2>
    <p>Alle Ergebnisse sind sorgfältig erstellt, aber ohne Gewähr. Bei rechts-, gesundheits- oder finanzkritischen Fragen bitte fachlichen Rat einholen.</p>
  </div>
</BaseLayout>
