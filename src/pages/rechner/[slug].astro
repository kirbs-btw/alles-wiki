---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Calculator from '../../components/Calculator.astro';
import ToolCard from '../../components/ToolCard.astro';
import { TOOLS, getTool, relatedTools } from '../../lib/registry';
import { getCategory } from '../../lib/categories';
import { softwareAppLd, breadcrumbLd, faqLd } from '../../lib/schema';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return TOOLS.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const tool = getTool(slug as string)!;
const cat = getCategory(tool.category)!;
const path = `/rechner/${tool.slug}`;
const related = relatedTools(tool);

// Passende Inhalte: Wissen/How-to, die diesen Rechner verlinken – sonst aus derselben Kategorie.
function pickArticles<T extends { id: string; data: { related?: string[]; category: string } }>(entries: T[]): T[] {
  const direct = entries.filter((e) => (e.data.related ?? []).includes(tool.slug));
  const rest = entries.filter((e) => e.data.category === tool.category && !direct.includes(e));
  return [...direct, ...rest].slice(0, 3);
}
const wissenLinks = pickArticles(await getCollection('wissen', ({ data }) => !data.draft));
const howtoLinks = pickArticles(await getCollection('howto', ({ data }) => !data.draft));

const crumbs = [
  { name: 'Start', href: '/' },
  { name: cat.name, href: `/kategorie/${cat.slug}` },
  { name: tool.shortTitle ?? tool.title, href: path },
];

const ld: object[] = [
  softwareAppLd(tool, path),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
];
if (tool.faq && tool.faq.length > 0) ld.push(faqLd(tool.faq));
---

<BaseLayout title={tool.title} description={tool.description} path={path} ogType="article" jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <h1 class="text-3xl font-extrabold tracking-tight text-zinc-900">{tool.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{tool.description}</p>
      {tool.updated && <p class="mt-1 text-xs text-zinc-500">Aktualisiert: {tool.updated}</p>}
    </header>

    <div class="mt-8">
      <Calculator tool={tool} />
    </div>

    {tool.intro && <div class="prose-werkbank mt-12 max-w-none" set:html={tool.intro} />}

    {
      tool.howto && tool.howto.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold tracking-tight text-zinc-900">So funktioniert's</h2>
          <ol class="mt-3 list-decimal space-y-2 pl-5 text-zinc-600">
            {tool.howto.map((s) => (
              <li>{s}</li>
            ))}
          </ol>
        </section>
      )
    }

    {
      tool.faq && tool.faq.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
          <div class="mt-4 space-y-3">
            {tool.faq.map((f) => (
              <details class="rounded-lg border border-zinc-200 bg-white p-4">
                <summary class="cursor-pointer font-medium text-zinc-800">{f.q}</summary>
                <p class="mt-2 text-zinc-600">{f.a}</p>
              </details>
            ))}
          </div>
        </section>
      )
    }

    {
      related.length > 0 && (
        <section class="mt-12">
          <h2 class="text-2xl font-bold tracking-tight text-zinc-900">Verwandte Rechner</h2>
          <div class="mt-4 grid gap-5 sm:grid-cols-2">
            {related.map((t) => (
              <ToolCard tool={t} />
            ))}
          </div>
        </section>
      )
    }

    {
      (wissenLinks.length > 0 || howtoLinks.length > 0) && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Ratgeber & Anleitungen</h2>
          <p class="mt-1 text-sm text-zinc-600">Hintergrund und Schritt für Schritt zum Thema:</p>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {wissenLinks.map((e) => (
              <a
                href={`/wissen/${e.id}/`}
                class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md"
              >
                <span class="text-xs font-semibold text-brand-700">Wissen</span>
                <span class="mt-0.5 block font-medium text-zinc-800">{e.data.title}</span>
              </a>
            ))}
            {howtoLinks.map((e) => (
              <a
                href={`/how-to/${e.id}/`}
                class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md"
              >
                <span class="text-xs font-semibold text-brand-700">Anleitung</span>
                <span class="mt-0.5 block font-medium text-zinc-800">{e.data.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
