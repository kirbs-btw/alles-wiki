---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { SITE } from '../config/site';
import { CATEGORIES } from '../lib/categories';
import { TOOLS, TOTAL_TOOLS, categoryCount } from '../lib/registry';
import { websiteLd, organizationLd } from '../lib/schema';
import { getCollection } from 'astro:content';
import { GENERATORS } from '../lib/generators';

const popular = TOOLS.slice(0, 6);
const wissenCount = (await getCollection('wissen', ({ data }) => !data.draft)).length;
const howtoCount = (await getCollection('howto', ({ data }) => !data.draft)).length;
const genCount = GENERATORS.length;
---

<BaseLayout
  title={`${SITE.name} – ${SITE.tagline}`}
  description={SITE.description}
  path="/"
  jsonLd={[websiteLd(), organizationLd()]}
>
  <section class="relative overflow-hidden bg-zinc-900 text-white">
    <div class="blueprint-grid absolute inset-0 opacity-70"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 text-center sm:py-24">
      <span class="inline-flex items-center rounded-full border border-zinc-700 bg-zinc-800/60 px-3 py-1 text-xs font-medium text-brand-300">
        {TOTAL_TOOLS} Rechner · {wissenCount} Wissens-Artikel · {howtoCount} Anleitungen · {genCount} Generatoren
      </span>
      <h1 class="mx-auto mt-5 max-w-3xl text-4xl font-extrabold tracking-tight sm:text-5xl">
        Rechner, Wissen & How-to für <span class="text-brand-400">jeden Alltag</span>
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-zinc-300">
        AllesWiki beantwortet die alltäglichen Fragen aus ganz Deutschland – von Finanzen und Gesundheit
        über Auto, Wohnen und Recht bis Familie. Präzise, verständlich, ohne Anmeldung.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/rechner" class="rounded-lg bg-brand-700 px-5 py-3 font-semibold text-white transition hover:bg-brand-600">
          Alle Rechner ansehen
        </a>
        <a href="#kategorien" class="rounded-lg border border-zinc-700 px-5 py-3 font-semibold text-zinc-200 transition hover:bg-zinc-800">
          Kategorien entdecken
        </a>
      </div>
    </div>
  </section>

  <section id="kategorien" class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="text-2xl font-bold tracking-tight">Kategorien</h2>
    <p class="mt-1 text-zinc-500">Jedes große Alltagsthema – Schritt für Schritt mit Rechnern gefüllt.</p>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        CATEGORIES.map((c) => (
          <a
            href={`/kategorie/${c.slug}`}
            class="group rounded-xl border border-zinc-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md"
          >
            <div class="flex items-center gap-3">
              <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-brand-50 text-brand-700">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true" focusable="false">
                  <path d={c.icon} stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <h3 class="text-base font-semibold text-zinc-900 group-hover:text-brand-700">{c.name}</h3>
                <span class="text-xs text-zinc-500">{categoryCount(c.slug)} Rechner</span>
              </div>
            </div>
            <p class="mt-3 text-sm text-zinc-500">{c.tagline}</p>
          </a>
        ))
      }
    </div>
  </section>

  {
    popular.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 pb-16">
        <div class="flex items-end justify-between">
          <h2 class="text-2xl font-bold tracking-tight">Beliebte Rechner</h2>
          <a href="/rechner" class="text-sm font-medium text-brand-700 hover:underline">
            Alle ansehen →
          </a>
        </div>
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {popular.map((t) => (
            <ToolCard tool={t} />
          ))}
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <h2 class="text-2xl font-bold tracking-tight">Mehr als Rechner</h2>
    <p class="mt-1 text-zinc-500">Verstehen, anwenden, ausprobieren.</p>
    <div class="mt-8 grid gap-5 sm:grid-cols-3">
      <a href="/wissen" class="group rounded-xl border border-zinc-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
        <h3 class="text-base font-semibold text-zinc-900 group-hover:text-brand-700">Wissen</h3>
        <p class="mt-2 text-sm text-zinc-500">{wissenCount} verständliche Artikel, die die Themen hinter den Rechnern erklären.</p>
      </a>
      <a href="/how-to" class="group rounded-xl border border-zinc-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
        <h3 class="text-base font-semibold text-zinc-900 group-hover:text-brand-700">How-to</h3>
        <p class="mt-2 text-sm text-zinc-500">{howtoCount} Schritt-für-Schritt-Anleitungen für die Aufgaben des Alltags.</p>
      </a>
      <a href="/generator" class="group rounded-xl border border-zinc-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
        <h3 class="text-base font-semibold text-zinc-900 group-hover:text-brand-700">Generatoren</h3>
        <p class="mt-2 text-sm text-zinc-500">{genCount} interaktive Tools: Passwort, QR-Code, Tilgungsplan und mehr.</p>
      </a>
    </div>
  </section>

  <section class="border-t border-zinc-200 bg-white">
    <div class="prose-werkbank mx-auto max-w-3xl px-4 py-12">
      <h2>Ein Nachschlagewerk für den deutschen Alltag</h2>
      <p>
        {SITE.name} bündelt an einem Ort, was man in Deutschland ständig nachrechnen oder nachschlagen muss –
        kostenlos und ohne Anmeldung. Rechner, Wissen, Anleitungen und interaktive Generatoren zu jedem
        großen Thema – ständig erweitert.
      </p>
      <h3>Rechner, Wissen, How-to & Generatoren</h3>
      <p>
        Die Rechner reichen von Brutto-Netto, Mehrwertsteuer und Kredit über BMI, Spritkosten und Stromkosten
        bis Mietnebenkosten und Notendurchschnitt. Dazu kommen verständliche Wissens-Artikel, praktische
        Schritt-für-Schritt-Anleitungen und interaktive Generatoren zu denselben Themen – alles miteinander
        verlinkt, damit du vom Nachschlagen direkt zum Ausrechnen kommst.
      </p>
      <h3>Verständlich und transparent</h3>
      <p>
        Jeder Rechner zeigt die verwendete Formel, eine kurze Anleitung und Antworten auf häufige Fragen. Die
        Berechnungen laufen direkt im Browser – deine Eingaben verlassen dein Gerät nicht.
      </p>
    </div>
  </section>
</BaseLayout>
