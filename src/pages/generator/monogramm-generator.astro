---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('monogramm-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-4 sm:grid-cols-3">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Vorname</span>
          <input
            id="mono-first"
            type="text"
            autocomplete="off"
            placeholder="z. B. Anna"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Mittelname <span class="font-normal text-zinc-400">(optional)</span></span>
          <input
            id="mono-middle"
            type="text"
            autocomplete="off"
            placeholder="z. B. Maria"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Nachname</span>
          <input
            id="mono-last"
            type="text"
            autocomplete="off"
            placeholder="z. B. Schmidt"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
      </div>

      <div class="mt-4 flex items-center gap-2">
        <button id="mono-gen" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Erzeugen</button>
        <p id="mono-msg" class="text-xs text-zinc-500" aria-live="polite">Gib mindestens einen Namen ein.</p>
      </div>

      <div id="mono-results" class="mt-6 grid gap-3" aria-live="polite"></div>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const first = document.getElementById('mono-first') as HTMLInputElement | null;
      const middle = document.getElementById('mono-middle') as HTMLInputElement | null;
      const last = document.getElementById('mono-last') as HTMLInputElement | null;
      const genBtn = document.getElementById('mono-gen');
      const msg = document.getElementById('mono-msg');
      const results = document.getElementById('mono-results');

      // Erstes Zeichen als Großbuchstabe holen. Umlaute werden auf den Grundbuchstaben
      // abgebildet (Ä->A, Ö->O, Ü->U, ß->S), damit ein klassisches Monogramm entsteht.
      const initialOf = (raw: string): string => {
        const name = (raw ?? '').trim();
        if (!name) return '';
        // Erstes "Wort" nehmen (falls jemand mehrere Wörter eingibt).
        const word = name.split(/\s+/)[0] ?? '';
        const ch = word.charAt(0).toLocaleUpperCase('de-DE');
        const map: Record<string, string> = { 'Ä': 'A', 'Ö': 'O', 'Ü': 'U', 'ß': 'S' };
        if (map[ch]) return map[ch];
        // Akzente entfernen (z. B. É -> E), Rest unverändert lassen.
        return ch.normalize('NFD').replace(/[̀-ͯ]/g, '') || ch;
      };

      const makeCard = (label: string, value: string): HTMLDivElement => {
        const card = document.createElement('div');
        card.className = 'flex items-center justify-between gap-3 rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3';
        const text = document.createElement('div');
        const lab = document.createElement('div');
        lab.className = 'text-xs font-medium text-zinc-500';
        lab.textContent = label;
        const val = document.createElement('div');
        val.className = 'mt-0.5 font-mono text-lg font-semibold text-zinc-900';
        val.textContent = value;
        text.appendChild(lab);
        text.appendChild(val);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'shrink-0 rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300';
        btn.textContent = 'Kopieren';
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(value);
            btn.textContent = 'Kopiert';
            setTimeout(() => { btn.textContent = 'Kopieren'; }, 1500);
          } catch {
            // Fallback: Auswahl-Selektion über temporäres Input-Element.
            const tmp = document.createElement('input');
            tmp.value = value;
            document.body.appendChild(tmp);
            tmp.select();
            try { document.execCommand('copy'); btn.textContent = 'Kopiert'; }
            catch { btn.textContent = 'Strg+C'; }
            document.body.removeChild(tmp);
            setTimeout(() => { btn.textContent = 'Kopieren'; }, 1500);
          }
        });

        card.appendChild(text);
        card.appendChild(btn);
        return card;
      };

      const generate = () => {
        if (!results || !msg) return;
        results.innerHTML = '';

        const f = initialOf(first?.value ?? '');
        const m = initialOf(middle?.value ?? '');
        const l = initialOf(last?.value ?? '');

        const parts = [f, m, l].filter(Boolean);
        if (parts.length === 0) {
          msg.textContent = 'Bitte gib mindestens einen Namen ein.';
          return;
        }

        const variants: { label: string; value: string }[] = [];
        const seen = new Set<string>();
        const add = (label: string, value: string) => {
          if (!value) return;
          const key = label + '|' + value;
          if (seen.has(key)) return;
          seen.add(key);
          variants.push({ label, value });
        };

        if (m) {
          // Drei Namen vorhanden.
          add('Initialen (Vor · Mittel · Nach)', `${f}${m}${l}`);
          add('Mit Punkten', `${f}.${m}.${l}.`);
          // Klassisch: Nachname-Buchstabe größer in der Mitte (hier durch · hervorgehoben).
          add('Klassisch (Nachname betont, Mitte)', `${f} · ${l} · ${m}`);
          add('Mit Bindestrich', `${f}-${m}-${l}`);
          add('Punkte (V.N.)', `${f}.${l}.`);
        } else if (f && l) {
          // Zwei Namen (Vor- und Nachname).
          add('Initialen (Vor · Nach)', `${f}${l}`);
          add('Mit Punkten', `${f}.${l}.`);
          add('Umgekehrt (Nach · Vor)', `${l}${f}`);
          add('Klassisch (Nachname betont, Mitte)', `${f} · ${l}`);
          add('Mit Bindestrich', `${f}-${l}`);
        } else {
          // Nur ein Name vorhanden.
          const single = parts[0];
          add('Einzelinitiale', single);
          add('Mit Punkt', `${single}.`);
        }

        for (const v of variants) {
          results.appendChild(makeCard(v.label, v.value));
        }
        msg.textContent = `${variants.length} Variante${variants.length === 1 ? '' : 'n'} erzeugt.`;
      };

      genBtn?.addEventListener('click', generate);
      // Live-Aktualisierung bei Eingabe.
      [first, middle, last].forEach((el) => el?.addEventListener('input', generate));
    }
  </script>
</BaseLayout>
