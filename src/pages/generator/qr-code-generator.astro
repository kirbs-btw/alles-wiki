---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('qr-code-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-5 sm:grid-cols-2">
        <div class="flex flex-col gap-5">
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-zinc-700">Text oder Link</span>
            <textarea
              id="qr-text"
              rows="4"
              class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
            >https://www.alles-wiki.de</textarea>
          </label>

          <label class="block">
            <span class="mb-1 block text-sm font-medium text-zinc-700">Fehlerkorrektur</span>
            <select
              id="qr-level"
              class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
            >
              <option value="L">L – niedrig (~7 %)</option>
              <option value="M" selected>M – mittel (~15 %)</option>
              <option value="Q">Q – hoch (~25 %)</option>
              <option value="H">H – sehr hoch (~30 %)</option>
            </select>
          </label>

          <div class="flex flex-wrap gap-2">
            <button id="qr-svg" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Als SVG herunterladen</button>
            <button id="qr-png" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-4 py-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Als PNG herunterladen</button>
          </div>
        </div>

        <div class="flex flex-col items-center justify-center">
          <label class="sr-only" for="qr-out">Generierter QR-Code</label>
          <div
            id="qr-out"
            class="flex aspect-square w-full max-w-[16rem] items-center justify-center rounded-lg border border-zinc-200 bg-white p-3 [&_svg]:h-full [&_svg]:w-full"
          ></div>
        </div>
      </div>
      <p id="qr-msg" class="mt-4 text-xs text-zinc-500" aria-live="polite">Erzeugt lokal in deinem Browser – deine Eingaben werden nicht übertragen.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    import qrcode from 'qrcode-generator';

    type ErrorLevel = 'L' | 'M' | 'Q' | 'H';

    // UTF-8-Encoder registrieren, damit Umlaute, Emojis und andere
    // Mehrbyte-Zeichen korrekt kodiert werden (statt charCodeAt & 0xff).
    qrcode.stringToBytesFuncs['UTF-8'] = (s: string) => Array.from(new TextEncoder().encode(s));
    qrcode.stringToBytes = qrcode.stringToBytesFuncs['UTF-8'];

    const root = document.querySelector('[data-gen]');
    if (root) {
      const textEl = document.getElementById('qr-text') as HTMLTextAreaElement | null;
      const levelEl = document.getElementById('qr-level') as HTMLSelectElement | null;
      const out = document.getElementById('qr-out') as HTMLElement | null;
      const msg = document.getElementById('qr-msg') as HTMLElement | null;
      const svgBtn = document.getElementById('qr-svg') as HTMLButtonElement | null;
      const pngBtn = document.getElementById('qr-png') as HTMLButtonElement | null;

      if (textEl && levelEl && out && msg && svgBtn && pngBtn) {
        // Aktueller QR-Code – wird bei jeder Eingabe neu gebaut.
        let current: ReturnType<typeof qrcode> | null = null;

        const slug = () => {
          const raw = textEl.value.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
          return (raw || 'qr-code').slice(0, 40);
        };

        const render = () => {
          const text = textEl.value;
          if (!text.trim()) {
            current = null;
            out.innerHTML = '';
            msg.textContent = 'Bitte Text oder Link eingeben, um einen QR-Code zu erzeugen.';
            svgBtn.disabled = true;
            pngBtn.disabled = true;
            svgBtn.classList.add('opacity-50', 'cursor-not-allowed');
            pngBtn.classList.add('opacity-50', 'cursor-not-allowed');
            return;
          }
          const level = (levelEl.value as ErrorLevel) || 'M';
          try {
            const qr = qrcode(0, level);
            qr.addData(text, 'Byte');
            qr.make();
            current = qr;
            // `title` ergibt im SVG ein <title>-Element samt role/aria-labelledby
            // (Cast, da die Typdeklaration der Bibliothek diese Option nicht kennt).
            out.innerHTML = qr.createSvgTag({ scalable: true, margin: 2, title: 'QR-Code für ' + text } as { scalable: boolean; margin: number });
            msg.textContent = 'Erzeugt lokal in deinem Browser – deine Eingaben werden nicht übertragen.';
            svgBtn.disabled = false;
            pngBtn.disabled = false;
            svgBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            pngBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          } catch {
            current = null;
            out.innerHTML = '';
            msg.textContent = 'Der Inhalt ist zu lang für einen QR-Code. Bitte kürze den Text.';
            svgBtn.disabled = true;
            pngBtn.disabled = true;
            svgBtn.classList.add('opacity-50', 'cursor-not-allowed');
            pngBtn.classList.add('opacity-50', 'cursor-not-allowed');
          }
        };

        const triggerDownload = (url: string, filename: string) => {
          const a = document.createElement('a');
          a.href = url;
          a.download = filename;
          document.body.appendChild(a);
          a.click();
          a.remove();
        };

        // SVG-Download: Markup aus dem Container als Blob speichern.
        svgBtn.addEventListener('click', () => {
          const svg = out.querySelector('svg');
          if (!current || !svg) return;
          const markup = '<?xml version="1.0" encoding="UTF-8"?>\n' + svg.outerHTML;
          const blob = new Blob([markup], { type: 'image/svg+xml;charset=utf-8' });
          const url = URL.createObjectURL(blob);
          triggerDownload(url, slug() + '.svg');
          setTimeout(() => URL.revokeObjectURL(url), 1000);
          msg.textContent = 'QR-Code als SVG heruntergeladen.';
        });

        // PNG-Download: SVG auf ein Canvas zeichnen und als PNG exportieren.
        pngBtn.addEventListener('click', () => {
          const svg = out.querySelector('svg');
          if (!current || !svg) return;
          const size = 512;
          // Für die Rasterisierung explizite Maße ergänzen (das scalable-SVG
          // im DOM hat nur eine viewBox, wodurch naturalWidth/Height 0 wäre).
          const markup = new XMLSerializer()
            .serializeToString(svg)
            .replace('<svg ', `<svg width="${size}" height="${size}" `);
          const svgUrl = URL.createObjectURL(new Blob([markup], { type: 'image/svg+xml;charset=utf-8' }));
          const img = new Image();
          img.onload = () => {
            const canvas = document.createElement('canvas');
            canvas.width = size;
            canvas.height = size;
            const ctx = canvas.getContext('2d');
            if (!ctx) {
              URL.revokeObjectURL(svgUrl);
              msg.textContent = 'PNG konnte nicht erstellt werden.';
              return;
            }
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, size, size);
            ctx.drawImage(img, 0, 0, size, size);
            URL.revokeObjectURL(svgUrl);
            canvas.toBlob((blob) => {
              if (!blob) {
                msg.textContent = 'PNG konnte nicht erstellt werden.';
                return;
              }
              const url = URL.createObjectURL(blob);
              triggerDownload(url, slug() + '.png');
              setTimeout(() => URL.revokeObjectURL(url), 1000);
              msg.textContent = 'QR-Code als PNG heruntergeladen.';
            }, 'image/png');
          };
          img.onerror = () => {
            URL.revokeObjectURL(svgUrl);
            // Fallback: GIF-DataURL der Bibliothek nutzen.
            if (current) {
              triggerDownload(current.createDataURL(8, 8), slug() + '.gif');
              msg.textContent = 'QR-Code als Bild heruntergeladen.';
            }
          };
          img.src = svgUrl;
        });

        textEl.addEventListener('input', render);
        levelEl.addEventListener('change', render);
        render();
      }
    }
  </script>
</BaseLayout>
