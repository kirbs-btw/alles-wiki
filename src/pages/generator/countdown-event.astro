---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('countdown-event')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Zieldatum</span>
          <input
            id="cd-date"
            type="date"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Uhrzeit</span>
          <input
            id="cd-time"
            type="time"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
      </div>

      <div id="cd-result" class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4" aria-hidden="true">
        <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-center">
          <div id="cd-days" class="font-mono text-3xl font-extrabold tabular-nums text-brand-700">0</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wide text-zinc-500">Tage</div>
        </div>
        <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-center">
          <div id="cd-hours" class="font-mono text-3xl font-extrabold tabular-nums text-brand-700">0</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wide text-zinc-500">Stunden</div>
        </div>
        <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-center">
          <div id="cd-mins" class="font-mono text-3xl font-extrabold tabular-nums text-brand-700">0</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wide text-zinc-500">Minuten</div>
        </div>
        <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-center">
          <div id="cd-secs" class="font-mono text-3xl font-extrabold tabular-nums text-brand-700">0</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wide text-zinc-500">Sekunden</div>
        </div>
      </div>

      <p id="cd-msg" class="mt-4 text-sm font-medium text-zinc-700" aria-live="polite">Wähle ein Zieldatum, um den Countdown zu starten.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const dateEl = document.getElementById('cd-date') as HTMLInputElement | null;
      const timeEl = document.getElementById('cd-time') as HTMLInputElement | null;
      const resultEl = document.getElementById('cd-result') as HTMLElement | null;
      const daysEl = document.getElementById('cd-days') as HTMLElement | null;
      const hoursEl = document.getElementById('cd-hours') as HTMLElement | null;
      const minsEl = document.getElementById('cd-mins') as HTMLElement | null;
      const secsEl = document.getElementById('cd-secs') as HTMLElement | null;
      const msg = document.getElementById('cd-msg') as HTMLElement | null;

      if (dateEl && timeEl && resultEl && daysEl && hoursEl && minsEl && secsEl && msg) {
        let timer: ReturnType<typeof setInterval> | null = null;

        const pad = (n: number) => String(n).padStart(2, '0');

        const showResult = (show: boolean) => {
          resultEl.setAttribute('aria-hidden', show ? 'false' : 'true');
          resultEl.style.display = show ? '' : 'none';
        };

        // Zielzeitpunkt aus Datum + (optionaler) Uhrzeit zusammensetzen.
        const getTarget = (): Date | null => {
          const dVal = dateEl.value;
          if (!dVal) return null;
          const tVal = timeEl.value || '00:00';
          const target = new Date(`${dVal}T${tVal}`);
          if (isNaN(target.getTime())) return null;
          return target;
        };

        const stop = () => {
          if (timer !== null) {
            clearInterval(timer);
            timer = null;
          }
        };

        const tick = () => {
          const target = getTarget();
          if (!target) {
            stop();
            showResult(false);
            msg.textContent = 'Bitte ein gültiges Zieldatum wählen.';
            return;
          }

          const diff = target.getTime() - Date.now();

          if (diff <= 0) {
            // Ziel erreicht oder bereits vergangen.
            stop();
            const passed = Math.abs(diff);
            const dayMs = 86400000;
            const days = Math.floor(passed / dayMs);
            daysEl.textContent = String(days);
            hoursEl.textContent = pad(Math.floor((passed % dayMs) / 3600000));
            minsEl.textContent = pad(Math.floor((passed % 3600000) / 60000));
            secsEl.textContent = pad(Math.floor((passed % 60000) / 1000));
            showResult(true);
            msg.textContent =
              passed < 60000
                ? 'Der Zeitpunkt ist erreicht! 🎉'
                : 'Der Zeitpunkt ist bereits vergangen – so lange ist es her.';
            return;
          }

          const dayMs = 86400000;
          const days = Math.floor(diff / dayMs);
          // Tage können sehr groß werden, daher nur die Anzahl deckeln wir nicht künstlich,
          // sondern zeigen sie direkt – setInterval erzeugt aber nur 1 Update/Sekunde.
          daysEl.textContent = String(days);
          hoursEl.textContent = pad(Math.floor((diff % dayMs) / 3600000));
          minsEl.textContent = pad(Math.floor((diff % 3600000) / 60000));
          secsEl.textContent = pad(Math.floor((diff % 60000) / 1000));
          showResult(true);
          msg.textContent = 'Countdown läuft – aktualisiert jede Sekunde.';
        };

        const start = () => {
          stop();
          const target = getTarget();
          if (!target) {
            showResult(false);
            msg.textContent = dateEl.value
              ? 'Bitte ein gültiges Zieldatum wählen.'
              : 'Wähle ein Zieldatum, um den Countdown zu starten.';
            return;
          }
          tick();
          // Nur weiterticken lassen, wenn das Ziel noch in der Zukunft liegt.
          if (target.getTime() - Date.now() > 0) {
            timer = setInterval(tick, 1000);
          }
        };

        dateEl.addEventListener('input', start);
        timeEl.addEventListener('input', start);

        // Initialzustand: Ergebnis ausblenden, bis ein Datum gewählt wurde.
        showResult(false);
        start();
      }
    }
  </script>
</BaseLayout>
