---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('schere-stein-papier')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <p class="text-sm font-medium text-zinc-700">Triff deine Wahl:</p>
      <div class="mt-3 grid grid-cols-3 gap-3" role="group" aria-label="Schere, Stein oder Papier wählen">
        <button id="ssp-schere" type="button" data-move="schere" class="flex flex-col items-center justify-center gap-1 rounded-lg bg-brand-700 px-4 py-5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">
          <span class="text-3xl" aria-hidden="true">✂️</span>
          <span>Schere</span>
        </button>
        <button id="ssp-stein" type="button" data-move="stein" class="flex flex-col items-center justify-center gap-1 rounded-lg bg-brand-700 px-4 py-5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">
          <span class="text-3xl" aria-hidden="true">🪨</span>
          <span>Stein</span>
        </button>
        <button id="ssp-papier" type="button" data-move="papier" class="flex flex-col items-center justify-center gap-1 rounded-lg bg-brand-700 px-4 py-5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">
          <span class="text-3xl" aria-hidden="true">📄</span>
          <span>Papier</span>
        </button>
      </div>

      <div id="ssp-result" class="mt-6 rounded-lg border border-zinc-200 bg-zinc-50 p-5 text-center" aria-live="polite">
        <p class="text-sm text-zinc-500">Wähle Schere, Stein oder Papier, um zu starten.</p>
      </div>

      <div class="mt-6 grid grid-cols-2 gap-3">
        <div class="rounded-lg border border-zinc-200 bg-white p-4 text-center">
          <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Du</p>
          <p id="ssp-score-you" class="mt-1 text-2xl font-extrabold text-brand-700">0</p>
        </div>
        <div class="rounded-lg border border-zinc-200 bg-white p-4 text-center">
          <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Computer</p>
          <p id="ssp-score-cpu" class="mt-1 text-2xl font-extrabold text-zinc-700">0</p>
        </div>
      </div>

      <div class="mt-4 flex items-center justify-between">
        <p id="ssp-msg" class="text-xs text-zinc-500" aria-live="polite">Fairer Zufall – der Computer kennt deinen Zug nicht.</p>
        <button id="ssp-reset" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-3 py-2 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Punktestand zurücksetzen</button>
      </div>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const resultEl = document.getElementById('ssp-result');
      const scoreYouEl = document.getElementById('ssp-score-you');
      const scoreCpuEl = document.getElementById('ssp-score-cpu');
      const msgEl = document.getElementById('ssp-msg');
      const resetEl = document.getElementById('ssp-reset');
      const buttons = Array.from(root.querySelectorAll('[data-move]'));

      if (resultEl && scoreYouEl && scoreCpuEl && buttons.length === 3) {
        type Move = 'schere' | 'stein' | 'papier';
        const moves: Move[] = ['schere', 'stein', 'papier'];
        const labels: Record<Move, string> = { schere: '✂️ Schere', stein: '🪨 Stein', papier: '📄 Papier' };
        // Was schlägt was: Schlüssel schlägt Wert.
        const beats: Record<Move, Move> = { schere: 'papier', stein: 'schere', papier: 'stein' };

        let scoreYou = 0;
        let scoreCpu = 0;

        // Unverzerrter Zufallsindex via Rejection-Sampling (vermeidet Modulo-Bias).
        const randIndex = (mod: number) => {
          const limit = Math.floor(2 ** 32 / mod) * mod;
          const buf = new Uint32Array(1);
          let v: number;
          do {
            crypto.getRandomValues(buf);
            v = buf[0];
          } while (v >= limit);
          return v % mod;
        };

        const play = (you: Move) => {
          const cpu = moves[randIndex(moves.length)];
          let verdict: string;
          let verdictClass: string;
          if (you === cpu) {
            verdict = 'Unentschieden';
            verdictClass = 'text-zinc-700';
          } else if (beats[you] === cpu) {
            verdict = 'Gewonnen';
            verdictClass = 'text-brand-700';
            scoreYou += 1;
          } else {
            verdict = 'Verloren';
            verdictClass = 'text-zinc-900';
            scoreCpu += 1;
          }

          scoreYouEl.textContent = String(scoreYou);
          scoreCpuEl.textContent = String(scoreCpu);

          resultEl.innerHTML =
            '<div class="flex items-center justify-center gap-6 text-zinc-800">' +
              '<div><p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Du</p>' +
              '<p class="mt-1 text-lg font-semibold">' + labels[you] + '</p></div>' +
              '<span class="text-zinc-400">vs.</span>' +
              '<div><p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Computer</p>' +
              '<p class="mt-1 text-lg font-semibold">' + labels[cpu] + '</p></div>' +
            '</div>' +
            '<p class="mt-3 text-xl font-extrabold ' + verdictClass + '">' + verdict + '</p>';
          if (msgEl) msgEl.textContent = 'Fairer Zufall – der Computer kennt deinen Zug nicht.';
        };

        buttons.forEach((btn) => {
          btn.addEventListener('click', () => {
            const move = btn.getAttribute('data-move') as Move | null;
            if (move && moves.includes(move)) play(move);
          });
        });

        resetEl?.addEventListener('click', () => {
          scoreYou = 0;
          scoreCpu = 0;
          scoreYouEl.textContent = '0';
          scoreCpuEl.textContent = '0';
          resultEl.innerHTML = '<p class="text-sm text-zinc-500">Wähle Schere, Stein oder Papier, um zu starten.</p>';
          if (msgEl) msgEl.textContent = 'Punktestand zurückgesetzt.';
        });
      }
    }
  </script>
</BaseLayout>
