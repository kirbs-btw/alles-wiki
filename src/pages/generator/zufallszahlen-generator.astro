---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('zufallszahlen-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-5 sm:grid-cols-3">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Min</span>
          <input
            id="rng-min"
            type="number"
            value="1"
            step="1"
            min="-1000000000"
            max="1000000000"
            inputmode="numeric"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Max</span>
          <input
            id="rng-max"
            type="number"
            value="49"
            step="1"
            min="-1000000000"
            max="1000000000"
            inputmode="numeric"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Anzahl</span>
          <input
            id="rng-count"
            type="number"
            value="6"
            min="1"
            max="10000"
            step="1"
            inputmode="numeric"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
      </div>

      <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex flex-col gap-2">
          <label class="flex items-center gap-2 text-sm text-zinc-700">
            <input id="rng-unique" type="checkbox" checked class="accent-brand-700" /> ohne Wiederholung
          </label>
          <label class="flex items-center gap-2 text-sm text-zinc-700">
            <input id="rng-sort" type="checkbox" class="accent-brand-700" /> aufsteigend sortieren
          </label>
        </div>
        <button id="rng-draw" type="button" class="shrink-0 rounded-lg bg-brand-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Ziehen</button>
      </div>

      <div id="rng-out" class="mt-6 flex flex-wrap gap-2" aria-live="polite"></div>
      <p id="rng-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Ziehung läuft lokal in deinem Browser über einen sicheren Zufallsgenerator.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const minEl = document.getElementById('rng-min') as HTMLInputElement | null;
      const maxEl = document.getElementById('rng-max') as HTMLInputElement | null;
      const countEl = document.getElementById('rng-count') as HTMLInputElement | null;
      const uniqueEl = document.getElementById('rng-unique') as HTMLInputElement | null;
      const sortEl = document.getElementById('rng-sort') as HTMLInputElement | null;
      const drawBtn = document.getElementById('rng-draw') as HTMLButtonElement | null;
      const out = document.getElementById('rng-out') as HTMLElement | null;
      const msg = document.getElementById('rng-msg') as HTMLElement | null;

      if (minEl && maxEl && countEl && uniqueEl && sortEl && drawBtn && out && msg) {
        // Obergrenzen gegen Speicher-/Endlosschleifen-Crashes.
        const MAX_RANGE = 1_000_000; // max. Pool-Groesse bei Ziehung ohne Wiederholung
        const MAX_COUNT = 10_000; // max. Anzahl gezogener Zahlen

        // Gleichverteilte Ganzzahl in [0, max) ohne Modulo-Bias.
        const randInt = (max: number): number => {
          if (max <= 0) return 0;
          // Bei max > 2^32 wuerde limit zu 0 werden -> Endlosschleife. Fallback ohne Crypto.
          if (max > 0x100000000) return Math.floor(Math.random() * max);
          // Wertebereich von Uint32Array ist [0, 2^32-1] = 2^32 Werte.
          const limit = Math.floor(0x100000000 / max) * max;
          const buf = new Uint32Array(1);
          let r: number;
          do {
            crypto.getRandomValues(buf);
            r = buf[0];
          } while (r >= limit);
          return r % max;
        };

        const renderChips = (nums: number[]) => {
          out.innerHTML = '';
          for (const n of nums) {
            const chip = document.createElement('span');
            chip.className =
              'inline-flex min-w-[2.5rem] items-center justify-center rounded-lg bg-brand-700 px-3 py-2 font-mono text-base font-semibold text-white';
            chip.textContent = String(n);
            out.appendChild(chip);
          }
        };

        const draw = () => {
          // Leere Felder werden von Number('') zu 0 -> explizit als ungueltig behandeln.
          if (
            minEl.value.trim() === '' ||
            maxEl.value.trim() === '' ||
            countEl.value.trim() === ''
          ) {
            out.innerHTML = '';
            msg.textContent = 'Bitte gültige Zahlen eingeben.';
            return;
          }

          let min = Math.round(Number(minEl.value));
          let max = Math.round(Number(maxEl.value));
          let count = Math.round(Number(countEl.value));

          if (!Number.isFinite(min) || !Number.isFinite(max) || !Number.isFinite(count)) {
            out.innerHTML = '';
            msg.textContent = 'Bitte gültige Zahlen eingeben.';
            return;
          }
          if (min > max) {
            const tmp = min;
            min = max;
            max = tmp;
          }
          if (count < 1) count = 1;
          if (count > MAX_COUNT) count = MAX_COUNT;

          const rangeSize = max - min + 1;
          let info = 'Ziehung läuft lokal in deinem Browser über einen sicheren Zufallsgenerator.';

          let result: number[];

          if (uniqueEl.checked) {
            // Pool ueber den gesamten Bereich -> Groesse hart begrenzen, sonst Crash/Freeze.
            if (rangeSize > MAX_RANGE) {
              out.innerHTML = '';
              msg.textContent = `Bereich zu groß für Ziehung ohne Wiederholung (max. ${MAX_RANGE.toLocaleString('de-DE')} Werte). Bitte Bereich verkleinern oder „ohne Wiederholung“ deaktivieren.`;
              return;
            }
            if (count > rangeSize) {
              count = rangeSize;
              info = `Ohne Wiederholung sind höchstens ${rangeSize} Zahlen möglich – Anzahl wurde begrenzt.`;
            }
            // Fisher-Yates über den gesamten Bereich.
            const pool: number[] = new Array(rangeSize);
            for (let i = 0; i < rangeSize; i++) pool[i] = min + i;
            for (let i = rangeSize - 1; i > 0; i--) {
              const j = randInt(i + 1);
              const t = pool[i];
              pool[i] = pool[j];
              pool[j] = t;
            }
            result = pool.slice(0, count);
          } else {
            result = new Array(count);
            for (let i = 0; i < count; i++) result[i] = min + randInt(rangeSize);
          }

          if (sortEl.checked) result.sort((a, b) => a - b);

          renderChips(result);
          msg.textContent = info;
        };

        drawBtn.addEventListener('click', draw);
        draw();
      }
    }
  </script>
</BaseLayout>
