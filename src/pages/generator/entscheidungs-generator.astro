---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('entscheidungs-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-zinc-700">Deine Optionen (eine pro Zeile)</span>
        <textarea
          id="dec-input"
          rows="5"
          class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 font-mono text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
        >Pizza
Pasta
Sushi</textarea>
      </label>

      <div class="mt-4 flex flex-wrap gap-2">
        <button id="dec-go" type="button" class="shrink-0 rounded-lg bg-brand-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Entscheiden</button>
        <button id="dec-copy" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-4 py-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Kopieren</button>
      </div>

      <div class="mt-6 rounded-lg border border-brand-200 bg-brand-50 p-6 text-center" aria-live="polite">
        <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Die Entscheidung lautet</p>
        <p id="dec-result" class="mt-2 break-words text-3xl font-extrabold text-zinc-900 sm:text-4xl">–</p>
      </div>

      <p id="dec-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Entscheidet lokal in deinem Browser – nichts wird übertragen.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const input = document.getElementById('dec-input') as HTMLTextAreaElement | null;
      const result = document.getElementById('dec-result') as HTMLElement | null;
      const msg = document.getElementById('dec-msg') as HTMLElement | null;
      const goBtn = document.getElementById('dec-go');
      const copyBtn = document.getElementById('dec-copy');

      // Obergrenze, damit nichts hängt.
      const MAX_OPTIONS = 1000;

      // Unverzerrter Zufallsindex via Rejection-Sampling (vermeidet Modulo-Bias).
      const randIndex = (mod: number) => {
        if (mod <= 1) return 0;
        const limit = Math.floor(2 ** 32 / mod) * mod;
        const buf = new Uint32Array(1);
        let v: number;
        do {
          crypto.getRandomValues(buf);
          v = buf[0];
        } while (v >= limit);
        return v % mod;
      };

      const decide = () => {
        if (!input || !result || !msg) return;
        const options = input.value
          .split('\n')
          .map((line) => line.trim())
          .filter((line) => line.length > 0)
          .slice(0, MAX_OPTIONS);

        if (options.length < 2) {
          result.textContent = '–';
          msg.textContent = 'Bitte mindestens zwei Optionen eingeben.';
          return;
        }

        const choice = options[randIndex(options.length)];
        result.textContent = choice;
        msg.textContent = `Aus ${options.length} Optionen fair ausgewählt.`;
      };

      goBtn?.addEventListener('click', decide);

      copyBtn?.addEventListener('click', async () => {
        if (!result || !msg) return;
        const text = result.textContent ?? '';
        if (!text || text === '–') {
          msg.textContent = 'Noch keine Entscheidung getroffen.';
          return;
        }
        try {
          await navigator.clipboard.writeText(text);
          msg.textContent = 'Ergebnis kopiert.';
        } catch {
          const sel = window.getSelection();
          const range = document.createRange();
          range.selectNodeContents(result);
          sel?.removeAllRanges();
          sel?.addRange(range);
          msg.textContent = 'Markiert – mit Strg/Cmd+C kopieren.';
        }
      });
    }
  </script>
</BaseLayout>
