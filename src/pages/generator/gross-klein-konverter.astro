---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('gross-klein-konverter')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-zinc-700">Dein Text</span>
        <textarea
          id="gkk-in"
          rows="5"
          placeholder="Text hier eingeben oder einfügen …"
          class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
        ></textarea>
      </label>

      <div class="mt-4 flex flex-wrap gap-2">
        <button id="gkk-upper" type="button" class="rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">GROSSBUCHSTABEN</button>
        <button id="gkk-lower" type="button" class="rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">kleinbuchstaben</button>
        <button id="gkk-title" type="button" class="rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Title Case</button>
        <button id="gkk-sentence" type="button" class="rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Satzanfang</button>
      </div>

      <div class="mt-5 flex flex-col gap-2">
        <span class="flex items-center justify-between text-sm font-medium text-zinc-700">
          <label for="gkk-out">Ergebnis</label>
          <button id="gkk-copy" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-3 py-1.5 text-xs font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Kopieren</button>
        </span>
        <textarea
          id="gkk-out"
          rows="5"
          readonly
          class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
        ></textarea>
      </div>

      <p id="gkk-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Text eingeben und eine Schreibweise wählen – alles passiert lokal in deinem Browser.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const input = document.getElementById('gkk-in') as HTMLTextAreaElement | null;
      const output = document.getElementById('gkk-out') as HTMLTextAreaElement | null;
      const msg = document.getElementById('gkk-msg') as HTMLElement | null;

      const toUpper = (s: string) => s.toLocaleUpperCase('de');
      const toLower = (s: string) => s.toLocaleLowerCase('de');

      // Jedes Wort groß: ersten Buchstaben einer Wortgruppe groß, Rest klein.
      const toTitle = (s: string) =>
        toLower(s).replace(/[\p{L}\p{N}]+/gu, (w) => toUpper(w.charAt(0)) + w.slice(1));

      // Nur Satzanfänge groß: alles klein, dann ersten Buchstaben am Text-/Satzanfang groß.
      const toSentence = (s: string) => {
        const lower = toLower(s);
        let result = '';
        let capitalizeNext = true;
        for (const ch of lower) {
          if (capitalizeNext && /\p{L}/u.test(ch)) {
            result += toUpper(ch);
            capitalizeNext = false;
          } else {
            result += ch;
            if (/[.!?]/.test(ch)) capitalizeNext = true;
          }
        }
        return result;
      };

      const apply = (fn: (s: string) => string, label: string) => {
        if (!input || !output || !msg) return;
        const value = input.value;
        if (!value.trim()) {
          output.value = '';
          msg.textContent = 'Bitte zuerst einen Text eingeben.';
          return;
        }
        try {
          output.value = fn(value);
          msg.textContent = `Umgewandelt: ${label}.`;
        } catch {
          msg.textContent = 'Der Text konnte nicht umgewandelt werden.';
        }
      };

      document.getElementById('gkk-upper')?.addEventListener('click', () => apply(toUpper, 'GROSSBUCHSTABEN'));
      document.getElementById('gkk-lower')?.addEventListener('click', () => apply(toLower, 'kleinbuchstaben'));
      document.getElementById('gkk-title')?.addEventListener('click', () => apply(toTitle, 'Title Case'));
      document.getElementById('gkk-sentence')?.addEventListener('click', () => apply(toSentence, 'Satzanfang'));

      document.getElementById('gkk-copy')?.addEventListener('click', async () => {
        if (!output || !msg || !output.value) return;
        try {
          await navigator.clipboard.writeText(output.value);
          msg.textContent = 'Ergebnis kopiert.';
        } catch {
          output.select();
          msg.textContent = 'Markiert – mit Strg/Cmd+C kopieren.';
        }
      });
    }
  </script>
</BaseLayout>
