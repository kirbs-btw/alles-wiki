---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('slug-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-zinc-700">Titel</span>
        <input
          id="slug-title"
          type="text"
          placeholder="z. B. Mein erster Blog-Beitrag über Café & Co."
          autocomplete="off"
          class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-3 text-lg text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
        />
      </label>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <label class="sr-only" for="slug-out">Erzeugter Slug</label>
        <input
          id="slug-out"
          type="text"
          readonly
          aria-live="polite"
          placeholder="dein-slug-erscheint-hier"
          class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 font-mono text-lg text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
        />
        <button id="slug-copy" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Kopieren</button>
      </div>

      <p id="slug-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Gib oben einen Titel ein – der Slug wird live erzeugt, alles lokal im Browser.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const titleEl = document.getElementById('slug-title') as HTMLInputElement | null;
      const out = document.getElementById('slug-out') as HTMLInputElement | null;
      const msg = document.getElementById('slug-msg') as HTMLElement | null;
      const copyBtn = document.getElementById('slug-copy');

      // Umlaute / ß ausschreiben, bevor Diakritika entfernt werden.
      const umlautMap: Record<string, string> = {
        ä: 'ae', ö: 'oe', ü: 'ue', ß: 'ss',
        Ä: 'ae', Ö: 'oe', Ü: 'ue',
      };

      const slugify = (input: string): string => {
        let s = (input ?? '').trim().toLowerCase();
        // Umlaute/ß ausschreiben (nach toLowerCase reichen die Kleinbuchstaben-Keys,
        // die Großbuchstaben-Keys bleiben als Sicherheit erhalten).
        s = s.replace(/[äöüßÄÖÜ]/g, (ch) => umlautMap[ch] ?? ch);
        // Akzente/Diakritika entfernen (z. B. é → e, ñ → n).
        s = s.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        // Alles außer a-z und 0-9 zu Bindestrich.
        s = s.replace(/[^a-z0-9]+/g, '-');
        // Mehrfach-Bindestriche zu einem.
        s = s.replace(/-{2,}/g, '-');
        // Rand-Bindestriche entfernen.
        s = s.replace(/^-+|-+$/g, '');
        return s;
      };

      const update = () => {
        if (!titleEl || !out || !msg) return;
        const raw = titleEl.value;
        const slug = slugify(raw);
        out.value = slug;
        if (!raw.trim()) {
          msg.textContent = 'Gib oben einen Titel ein – der Slug wird live erzeugt, alles lokal im Browser.';
        } else if (!slug) {
          msg.textContent = 'Aus diesem Titel lässt sich kein Slug bilden (nur Sonderzeichen?). Bitte Buchstaben oder Ziffern verwenden.';
        } else {
          msg.textContent = 'Slug erzeugt – mit „Kopieren“ in die Zwischenablage übernehmen.';
        }
      };

      titleEl?.addEventListener('input', update);

      copyBtn?.addEventListener('click', async () => {
        if (!out || !msg) return;
        if (!out.value) { msg.textContent = 'Es gibt noch keinen Slug zum Kopieren.'; return; }
        try {
          await navigator.clipboard.writeText(out.value);
          msg.textContent = 'Slug kopiert.';
        } catch {
          out.select();
          msg.textContent = 'Markiert – mit Strg/Cmd+C kopieren.';
        }
      });

      update();
    }
  </script>
</BaseLayout>
