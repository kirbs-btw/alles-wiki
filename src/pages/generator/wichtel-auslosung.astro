---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('wichtel-auslosung')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-zinc-700">Teilnehmer (eine Person pro Zeile)</span>
        <textarea
          id="wichtel-names"
          rows="6"
          class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 font-mono text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
        >Anna
Ben
Clara
David</textarea>
      </label>

      <div class="mt-4 flex flex-wrap gap-2">
        <button id="wichtel-draw" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Auslosen</button>
        <button id="wichtel-copy" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-4 py-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Kopieren</button>
      </div>

      <p id="wichtel-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Gib mindestens zwei Namen ein und klicke auf „Auslosen". Alles läuft lokal in deinem Browser.</p>

      <ul id="wichtel-result" class="mt-4 space-y-2" aria-live="polite"></ul>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const namesEl = document.getElementById('wichtel-names') as HTMLTextAreaElement | null;
      const resultEl = document.getElementById('wichtel-result') as HTMLElement | null;
      const msg = document.getElementById('wichtel-msg') as HTMLElement | null;
      const drawBtn = document.getElementById('wichtel-draw');
      const copyBtn = document.getElementById('wichtel-copy');

      const MAX = 200;
      let pairs: { from: string; to: string }[] = [];

      // Unverzerrter Zufallsindex via Rejection-Sampling (vermeidet Modulo-Bias).
      const randIndex = (mod: number) => {
        if (mod <= 1) return 0;
        const limit = Math.floor(2 ** 32 / mod) * mod;
        const buf = new Uint32Array(1);
        let v: number;
        do {
          crypto.getRandomValues(buf);
          v = buf[0];
        } while (v >= limit);
        return v % mod;
      };

      const parseNames = (): string[] => {
        if (!namesEl) return [];
        return namesEl.value
          .split('\n')
          .map((n) => n.trim())
          .filter((n) => n.length > 0)
          .slice(0, MAX);
      };

      const setMsg = (text: string) => {
        if (msg) msg.textContent = text;
      };

      const draw = () => {
        if (!resultEl) return;
        pairs = [];
        resultEl.innerHTML = '';

        const names = parseNames();
        if (names.length < 2) {
          setMsg('Bitte mindestens zwei Namen eingeben (eine Person pro Zeile).');
          return;
        }

        // Fisher-Yates-Shuffle der Namen.
        const order = names.slice();
        for (let i = order.length - 1; i > 0; i--) {
          const j = randIndex(i + 1);
          [order[i], order[j]] = [order[j], order[i]];
        }

        // Zyklische Zuordnung i -> i+1 garantiert ein Derangement:
        // niemand zieht sich selbst, und jeder beschenkt genau eine Person.
        const frag = document.createDocumentFragment();
        for (let i = 0; i < order.length; i++) {
          const from = order[i];
          const to = order[(i + 1) % order.length];
          pairs.push({ from, to });

          const li = document.createElement('li');
          li.className = 'flex items-center gap-2 rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm';
          const a = document.createElement('span');
          a.className = 'font-semibold text-zinc-900';
          a.textContent = from;
          const arrow = document.createElement('span');
          arrow.className = 'text-brand-700';
          arrow.textContent = '→';
          const b = document.createElement('span');
          b.className = 'font-semibold text-zinc-900';
          b.textContent = to;
          li.append(a, arrow, b);
          frag.appendChild(li);
        }
        resultEl.appendChild(frag);
        setMsg(`${pairs.length} Wichtel-Paare ausgelost. Niemand zieht sich selbst.`);
      };

      drawBtn?.addEventListener('click', draw);

      copyBtn?.addEventListener('click', async () => {
        if (pairs.length === 0) {
          setMsg('Noch nichts ausgelost – bitte zuerst auf „Auslosen" klicken.');
          return;
        }
        const text = pairs.map((p) => `${p.from} → ${p.to}`).join('\n');
        try {
          await navigator.clipboard.writeText(text);
          setMsg('Ergebnis kopiert.');
        } catch {
          setMsg('Kopieren nicht möglich – bitte Ergebnis manuell markieren.');
        }
      });
    }
  </script>
</BaseLayout>
