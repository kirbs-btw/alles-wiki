---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('farbpalette-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
        <label class="block" for="fp-picker">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Grundfarbe</span>
          <input
            id="fp-picker"
            type="color"
            value="#2563eb"
            class="h-12 w-20 cursor-pointer rounded-lg border border-zinc-300 bg-white p-1 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block flex-1" for="fp-hex">
          <span class="mb-1 block text-sm font-medium text-zinc-700">HEX-Code</span>
          <input
            id="fp-hex"
            type="text"
            value="#2563eb"
            spellcheck="false"
            autocomplete="off"
            placeholder="#2563eb"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 font-mono text-lg uppercase text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
      </div>
      <p id="fp-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Klicke auf eine Farbe, um ihren HEX-Code zu kopieren.</p>

      <!-- Abstufungen -->
      <div class="mt-8">
        <h2 class="text-sm font-semibold text-zinc-700">Abstufungen (heller → dunkler)</h2>
        <div id="fp-shades" class="mt-3 grid grid-cols-3 gap-2 sm:grid-cols-9"></div>
      </div>

      <!-- Harmonien -->
      <div class="mt-8">
        <h2 class="text-sm font-semibold text-zinc-700">Harmonische Schemata</h2>

        <div class="mt-3">
          <p class="mb-2 text-xs font-medium uppercase tracking-wide text-zinc-500">Komplementär</p>
          <div id="fp-complement" class="grid grid-cols-2 gap-2 sm:grid-cols-4"></div>
        </div>

        <div class="mt-4">
          <p class="mb-2 text-xs font-medium uppercase tracking-wide text-zinc-500">Analog</p>
          <div id="fp-analog" class="grid grid-cols-3 gap-2"></div>
        </div>

        <div class="mt-4">
          <p class="mb-2 text-xs font-medium uppercase tracking-wide text-zinc-500">Triade</p>
          <div id="fp-triad" class="grid grid-cols-3 gap-2"></div>
        </div>
      </div>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const picker = document.getElementById('fp-picker') as HTMLInputElement | null;
      const hexInput = document.getElementById('fp-hex') as HTMLInputElement | null;
      const msg = document.getElementById('fp-msg') as HTMLElement | null;
      const shadesEl = document.getElementById('fp-shades') as HTMLElement | null;
      const complementEl = document.getElementById('fp-complement') as HTMLElement | null;
      const analogEl = document.getElementById('fp-analog') as HTMLElement | null;
      const triadEl = document.getElementById('fp-triad') as HTMLElement | null;

      if (picker && hexInput && msg && shadesEl && complementEl && analogEl && triadEl) {
        // --- Farb-Umrechnung -------------------------------------------------
        const clamp = (n: number, min: number, max: number) => Math.min(max, Math.max(min, n));

        const normalizeHex = (raw: string): string | null => {
          let s = raw.trim().replace(/^#/, '');
          if (/^[0-9a-fA-F]{3}$/.test(s)) {
            s = s.split('').map((c) => c + c).join('');
          }
          if (/^[0-9a-fA-F]{6}$/.test(s)) {
            return '#' + s.toLowerCase();
          }
          return null;
        };

        interface RGB { r: number; g: number; b: number; }
        interface HSL { h: number; s: number; l: number; }

        const hexToRgb = (hex: string): RGB => {
          const s = hex.replace(/^#/, '');
          return {
            r: parseInt(s.slice(0, 2), 16),
            g: parseInt(s.slice(2, 4), 16),
            b: parseInt(s.slice(4, 6), 16),
          };
        };

        const rgbToHex = ({ r, g, b }: RGB): string => {
          const to = (n: number) => clamp(Math.round(n), 0, 255).toString(16).padStart(2, '0');
          return '#' + to(r) + to(g) + to(b);
        };

        const rgbToHsl = ({ r, g, b }: RGB): HSL => {
          const rn = r / 255, gn = g / 255, bn = b / 255;
          const max = Math.max(rn, gn, bn), min = Math.min(rn, gn, bn);
          const l = (max + min) / 2;
          let h = 0, s = 0;
          if (max !== min) {
            const d = max - min;
            s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
            switch (max) {
              case rn: h = (gn - bn) / d + (gn < bn ? 6 : 0); break;
              case gn: h = (bn - rn) / d + 2; break;
              default: h = (rn - gn) / d + 4; break;
            }
            h /= 6;
          }
          return { h: h * 360, s: s * 100, l: l * 100 };
        };

        const hslToRgb = ({ h, s, l }: HSL): RGB => {
          const hn = ((h % 360) + 360) % 360 / 360;
          const sn = clamp(s, 0, 100) / 100;
          const ln = clamp(l, 0, 100) / 100;
          if (sn === 0) {
            const v = Math.round(ln * 255);
            return { r: v, g: v, b: v };
          }
          const hue = (p: number, q: number, t: number): number => {
            let tt = t;
            if (tt < 0) tt += 1;
            if (tt > 1) tt -= 1;
            if (tt < 1 / 6) return p + (q - p) * 6 * tt;
            if (tt < 1 / 2) return q;
            if (tt < 2 / 3) return p + (q - p) * (2 / 3 - tt) * 6;
            return p;
          };
          const q = ln < 0.5 ? ln * (1 + sn) : ln + sn - ln * sn;
          const p = 2 * ln - q;
          return {
            r: Math.round(hue(p, q, hn + 1 / 3) * 255),
            g: Math.round(hue(p, q, hn) * 255),
            b: Math.round(hue(p, q, hn - 1 / 3) * 255),
          };
        };

        const hslToHex = (hsl: HSL): string => rgbToHex(hslToRgb(hsl));

        // --- Rendering -------------------------------------------------------
        const showMsg = (text: string) => { msg.textContent = text; };

        const copyHex = async (hex: string) => {
          try {
            await navigator.clipboard.writeText(hex);
            showMsg(hex.toUpperCase() + ' kopiert.');
          } catch {
            showMsg('Kopieren nicht möglich – HEX: ' + hex.toUpperCase());
          }
        };

        const swatch = (hex: string, label?: string): HTMLButtonElement => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className =
            'group flex w-full flex-col overflow-hidden rounded-lg border border-zinc-200 text-left transition hover:-translate-y-0.5 hover:shadow-md';
          const sw = document.createElement('span');
          sw.className = 'block h-12 w-full';
          sw.style.backgroundColor = hex;
          const code = document.createElement('span');
          code.className = 'block bg-white px-2 py-1 font-mono text-xs uppercase text-zinc-700';
          code.textContent = hex;
          btn.append(sw, code);
          const ariaLabel = (label ? label + ': ' : '') + hex.toUpperCase() + ' kopieren';
          btn.setAttribute('aria-label', ariaLabel);
          btn.addEventListener('click', () => copyHex(hex));
          return btn;
        };

        const fill = (container: HTMLElement, colors: string[]) => {
          container.replaceChildren(...colors.map((c) => swatch(c)));
        };

        const render = (hex: string) => {
          const base = rgbToHsl(hexToRgb(hex));

          // (a) Abstufungen: 9 Stufen über Lightness von hell (90 %) bis dunkel (10 %)
          const shades: string[] = [];
          for (let i = 0; i < 9; i++) {
            const l = 90 - i * 10; // 90,80,...,10
            shades.push(hslToHex({ h: base.h, s: base.s, l }));
          }
          fill(shadesEl, shades);

          // (b) Harmonien über Hue-Rotation
          // Komplementär (+180)
          fill(complementEl, [
            hslToHex(base),
            hslToHex({ h: base.h + 180, s: base.s, l: base.l }),
            hslToHex({ h: base.h, s: base.s, l: clamp(base.l + 18, 0, 95) }),
            hslToHex({ h: base.h + 180, s: base.s, l: clamp(base.l + 18, 0, 95) }),
          ]);

          // Analog (±30)
          fill(analogEl, [
            hslToHex({ h: base.h - 30, s: base.s, l: base.l }),
            hslToHex(base),
            hslToHex({ h: base.h + 30, s: base.s, l: base.l }),
          ]);

          // Triade (±120)
          fill(triadEl, [
            hslToHex(base),
            hslToHex({ h: base.h + 120, s: base.s, l: base.l }),
            hslToHex({ h: base.h + 240, s: base.s, l: base.l }),
          ]);
        };

        // --- Eingabe-Synchronisation ----------------------------------------
        const applyHex = (hex: string) => {
          picker.value = hex;
          hexInput.value = hex.toUpperCase();
          render(hex);
        };

        picker.addEventListener('input', () => {
          const hex = normalizeHex(picker.value);
          if (hex) {
            applyHex(hex);
            showMsg('Klicke auf eine Farbe, um ihren HEX-Code zu kopieren.');
          }
        });

        hexInput.addEventListener('input', () => {
          const hex = normalizeHex(hexInput.value);
          if (hex) {
            picker.value = hex;
            render(hex);
            showMsg('Klicke auf eine Farbe, um ihren HEX-Code zu kopieren.');
          } else {
            showMsg('Bitte einen gültigen HEX-Code eingeben, z. B. #2563eb.');
          }
        });

        hexInput.addEventListener('blur', () => {
          const hex = normalizeHex(hexInput.value);
          if (hex) hexInput.value = hex.toUpperCase();
        });

        // Initial
        applyHex('#2563eb');
      }
    }
  </script>
</BaseLayout>
