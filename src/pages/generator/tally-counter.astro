---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('tally-counter')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="flex flex-col items-center gap-6">
        <div class="text-center">
          <p class="text-sm font-medium text-zinc-500">Aktueller Stand</p>
          <p
            id="tc-value"
            aria-live="polite"
            class="mt-1 font-mono text-6xl font-extrabold tabular-nums text-zinc-900 sm:text-7xl"
          >0</p>
        </div>

        <div class="flex w-full max-w-sm items-center justify-center gap-3">
          <button
            id="tc-minus"
            type="button"
            aria-label="Runterzählen"
            class="flex h-16 w-16 shrink-0 items-center justify-center rounded-lg border border-zinc-300 text-3xl font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300"
          >−</button>
          <button
            id="tc-plus"
            type="button"
            aria-label="Hochzählen"
            class="flex h-24 flex-1 items-center justify-center rounded-lg bg-brand-700 text-4xl font-extrabold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300"
          >+</button>
        </div>

        <div class="grid w-full max-w-sm gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-zinc-700">Schrittweite</span>
            <input
              id="tc-step"
              type="number"
              min="1"
              step="1"
              value="1"
              class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
            />
          </label>
          <label class="flex items-end gap-2 text-sm text-zinc-700">
            <input id="tc-allow-negative" type="checkbox" class="accent-brand-700" />
            <span>Negative Werte erlauben</span>
          </label>
        </div>

        <button
          id="tc-reset"
          type="button"
          class="rounded-lg border border-zinc-300 px-5 py-2.5 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300"
        >Zurücksetzen</button>
      </div>
      <p id="tc-msg" class="mt-4 text-center text-xs text-zinc-500" aria-live="polite">Tippe auf „+" zum Hochzählen.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const valueEl = document.getElementById('tc-value') as HTMLElement | null;
      const plusEl = document.getElementById('tc-plus') as HTMLButtonElement | null;
      const minusEl = document.getElementById('tc-minus') as HTMLButtonElement | null;
      const resetEl = document.getElementById('tc-reset') as HTMLButtonElement | null;
      const stepEl = document.getElementById('tc-step') as HTMLInputElement | null;
      const allowNegEl = document.getElementById('tc-allow-negative') as HTMLInputElement | null;
      const msg = document.getElementById('tc-msg') as HTMLElement | null;

      if (valueEl) {
        let count = 0;

        const render = () => {
          valueEl.textContent = String(count);
        };

        // Schrittweite robust lesen: leere/ungültige Eingaben fallen auf 1 zurück, gedeckelt.
        const getStep = () => {
          const raw = stepEl ? parseInt(stepEl.value, 10) : 1;
          if (!Number.isFinite(raw) || raw < 1) return 1;
          return Math.min(raw, 1000000);
        };

        const setMsg = (text: string) => {
          if (msg) msg.textContent = text;
        };

        const allowNegative = () => Boolean(allowNegEl && allowNegEl.checked);

        plusEl?.addEventListener('click', () => {
          count += getStep();
          render();
          setMsg('Hochgezählt um ' + getStep() + '.');
        });

        minusEl?.addEventListener('click', () => {
          const next = count - getStep();
          if (next < 0 && !allowNegative()) {
            count = 0;
            render();
            setMsg('Untergrenze 0 erreicht. Für Minuswerte „Negative Werte erlauben" aktivieren.');
            return;
          }
          count = next;
          render();
          setMsg('Runtergezählt um ' + getStep() + '.');
        });

        resetEl?.addEventListener('click', () => {
          count = 0;
          render();
          setMsg('Zähler zurückgesetzt.');
        });

        // Wird Negativ-Option deaktiviert, sofort auf 0 anheben, falls nötig.
        allowNegEl?.addEventListener('change', () => {
          if (!allowNegative() && count < 0) {
            count = 0;
            render();
            setMsg('Negative Werte deaktiviert – Stand auf 0 gesetzt.');
          }
        });

        render();
      }
    }
  </script>
</BaseLayout>
