---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('css-gradient-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Farbe 1</span>
          <input
            id="grad-color1"
            type="color"
            value="#2563eb"
            class="h-11 w-full cursor-pointer rounded-lg border border-zinc-300 bg-white p-1 shadow-sm focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Farbe 2</span>
          <input
            id="grad-color2"
            type="color"
            value="#06b6d4"
            class="h-11 w-full cursor-pointer rounded-lg border border-zinc-300 bg-white p-1 shadow-sm focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Typ</span>
          <select
            id="grad-type"
            class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2.5 text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          >
            <option value="linear">Linear</option>
            <option value="radial">Radial</option>
          </select>
        </label>
        <label class="block" id="grad-angle-wrap">
          <span class="mb-1 flex items-center justify-between text-sm font-medium text-zinc-700">
            <span>Winkel</span>
            <span id="grad-angle-val" class="font-mono text-zinc-500">90°</span>
          </span>
          <input id="grad-angle" type="range" min="0" max="360" value="90" step="1" class="w-full accent-brand-700" />
        </label>
      </div>

      <div
        id="grad-preview"
        class="mt-6 h-40 w-full rounded-lg border border-zinc-200 shadow-inner"
        aria-hidden="true"
      ></div>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <label class="sr-only" for="grad-out">Generierter CSS-Code</label>
        <input
          id="grad-out"
          type="text"
          readonly
          aria-live="polite"
          class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 font-mono text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
        />
        <button id="grad-copy" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Kopieren</button>
      </div>
      <p id="grad-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Stelle Farben, Typ und Winkel ein – der CSS-Code aktualisiert sich automatisch.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const color1 = document.getElementById('grad-color1') as HTMLInputElement | null;
      const color2 = document.getElementById('grad-color2') as HTMLInputElement | null;
      const typeEl = document.getElementById('grad-type') as HTMLSelectElement | null;
      const angleEl = document.getElementById('grad-angle') as HTMLInputElement | null;
      const angleWrap = document.getElementById('grad-angle-wrap') as HTMLElement | null;
      const angleVal = document.getElementById('grad-angle-val') as HTMLElement | null;
      const preview = document.getElementById('grad-preview') as HTMLElement | null;
      const out = document.getElementById('grad-out') as HTMLInputElement | null;
      const msg = document.getElementById('grad-msg') as HTMLElement | null;
      const copyBtn = document.getElementById('grad-copy') as HTMLButtonElement | null;

      if (color1 && color2 && typeEl && angleEl && angleWrap && angleVal && preview && out && msg && copyBtn) {
        const update = () => {
          const c1 = color1.value || '#000000';
          const c2 = color2.value || '#ffffff';
          const type = typeEl.value === 'radial' ? 'radial' : 'linear';
          // Winkel auf 0–360 begrenzen, ungültige Eingaben auf 90 zurücksetzen.
          let angle = parseInt(angleEl.value, 10);
          if (Number.isNaN(angle)) angle = 90;
          angle = Math.min(360, Math.max(0, angle));
          angleVal.textContent = `${angle}°`;
          // Winkel-Regler nur bei linearem Verlauf anzeigen.
          angleWrap.style.display = type === 'linear' ? '' : 'none';

          const value =
            type === 'linear'
              ? `linear-gradient(${angle}deg, ${c1}, ${c2})`
              : `radial-gradient(circle, ${c1}, ${c2})`;
          const css = `background: ${value};`;
          preview.style.background = value;
          out.value = css;
          msg.textContent = 'Stelle Farben, Typ und Winkel ein – der CSS-Code aktualisiert sich automatisch.';
        };

        [color1, color2, typeEl, angleEl].forEach((el) => {
          el.addEventListener('input', update);
          el.addEventListener('change', update);
        });

        copyBtn.addEventListener('click', async () => {
          if (!out.value) return;
          try {
            await navigator.clipboard.writeText(out.value);
            msg.textContent = 'CSS-Code kopiert.';
          } catch {
            out.select();
            msg.textContent = 'Markiert – mit Strg/Cmd+C kopieren.';
          }
        });

        update();
      }
    }
  </script>
</BaseLayout>
