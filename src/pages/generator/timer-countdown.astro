---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('timer-countdown')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="text-center">
        <p
          id="timer-display"
          aria-live="polite"
          aria-atomic="true"
          class="font-mono text-6xl font-extrabold tracking-tight text-zinc-900 tabular-nums sm:text-7xl"
        >
          00:00
        </p>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Stunden</span>
          <input
            id="timer-hours"
            type="number"
            min="0"
            max="23"
            step="1"
            value="0"
            inputmode="numeric"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 text-center font-mono text-lg text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Minuten</span>
          <input
            id="timer-minutes"
            type="number"
            min="0"
            max="59"
            step="1"
            value="5"
            inputmode="numeric"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 text-center font-mono text-lg text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Sekunden</span>
          <input
            id="timer-seconds"
            type="number"
            min="0"
            max="59"
            step="1"
            value="0"
            inputmode="numeric"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 text-center font-mono text-lg text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
      </div>

      <div class="mt-6 flex flex-wrap justify-center gap-2">
        <button id="timer-start" type="button" class="rounded-lg bg-brand-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Start</button>
        <button id="timer-pause" type="button" class="rounded-lg border border-zinc-300 px-5 py-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Pause</button>
        <button id="timer-reset" type="button" class="rounded-lg border border-zinc-300 px-5 py-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Zurücksetzen</button>
      </div>

      <p id="timer-msg" class="mt-4 text-center text-xs text-zinc-500" aria-live="polite">Stelle eine Zeit ein und starte den Countdown.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const display = document.getElementById('timer-display');
      const hoursEl = document.getElementById('timer-hours') as HTMLInputElement | null;
      const minutesEl = document.getElementById('timer-minutes') as HTMLInputElement | null;
      const secondsEl = document.getElementById('timer-seconds') as HTMLInputElement | null;
      const startBtn = document.getElementById('timer-start');
      const pauseBtn = document.getElementById('timer-pause');
      const resetBtn = document.getElementById('timer-reset');
      const msg = document.getElementById('timer-msg');

      if (display && hoursEl && minutesEl && secondsEl && startBtn && pauseBtn && resetBtn && msg) {
        const MAX_SECONDS = 99 * 3600 + 59 * 60 + 59; // Deckel: knapp 100 Stunden.
        let remaining = 0; // verbleibende Sekunden
        let running = false;
        let intervalId: ReturnType<typeof setInterval> | null = null;

        const setMsg = (text: string) => { msg.textContent = text; };

        // Eingabe robust einlesen: leere/ungültige Felder werden als 0 behandelt, danach begrenzt.
        const clampInt = (raw: string, min: number, max: number): number => {
          const n = Math.floor(Number(raw));
          if (!Number.isFinite(n)) return min;
          return Math.min(max, Math.max(min, n));
        };

        const readInputs = (): number => {
          const h = clampInt(hoursEl.value, 0, 23);
          const m = clampInt(minutesEl.value, 0, 59);
          const s = clampInt(secondsEl.value, 0, 59);
          // Eingaben sichtbar normalisieren.
          hoursEl.value = String(h);
          minutesEl.value = String(m);
          secondsEl.value = String(s);
          let total = h * 3600 + m * 60 + s;
          if (total > MAX_SECONDS) total = MAX_SECONDS;
          return total;
        };

        const pad = (n: number) => String(n).padStart(2, '0');

        const render = () => {
          const h = Math.floor(remaining / 3600);
          const m = Math.floor((remaining % 3600) / 60);
          const s = remaining % 60;
          display.textContent = h > 0 ? `${pad(h)}:${pad(m)}:${pad(s)}` : `${pad(m)}:${pad(s)}`;
        };

        const setInputsDisabled = (disabled: boolean) => {
          hoursEl.disabled = disabled;
          minutesEl.disabled = disabled;
          secondsEl.disabled = disabled;
        };

        const stopInterval = () => {
          if (intervalId !== null) { clearInterval(intervalId); intervalId = null; }
        };

        // Kurzer Signalton via Web-Audio – in try/catch, da Autoplay-Policy blocken kann.
        const beep = () => {
          try {
            const Ctx = window.AudioContext || (window as any).webkitAudioContext;
            if (!Ctx) return;
            const ctx = new Ctx();
            const playTone = (start: number, freq: number) => {
              const osc = ctx.createOscillator();
              const gain = ctx.createGain();
              osc.type = 'sine';
              osc.frequency.value = freq;
              osc.connect(gain);
              gain.connect(ctx.destination);
              gain.gain.setValueAtTime(0.0001, ctx.currentTime + start);
              gain.gain.exponentialRampToValueAtTime(0.3, ctx.currentTime + start + 0.02);
              gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + start + 0.35);
              osc.start(ctx.currentTime + start);
              osc.stop(ctx.currentTime + start + 0.4);
            };
            playTone(0, 880);
            playTone(0.45, 880);
            playTone(0.9, 880);
            // Kontext nach den Tönen schließen.
            setTimeout(() => { try { ctx.close(); } catch (_e) { /* ignorieren */ } }, 1600);
          } catch (_e) {
            // Audio nicht erlaubt – stillschweigend ignorieren.
          }
        };

        const finish = () => {
          stopInterval();
          running = false;
          remaining = 0;
          render();
          setInputsDisabled(false);
          setMsg('Zeit abgelaufen!');
          beep();
        };

        const tick = () => {
          if (remaining <= 0) { finish(); return; }
          remaining -= 1;
          render();
          if (remaining <= 0) { finish(); }
        };

        const start = () => {
          if (running) return;
          // Wenn keine Restzeit vorhanden ist, aus den Eingaben neu laden.
          if (remaining <= 0) {
            remaining = readInputs();
          }
          if (remaining <= 0) {
            setMsg('Bitte zuerst eine Zeit größer als 0 einstellen.');
            render();
            return;
          }
          running = true;
          render();
          setInputsDisabled(true);
          setMsg('Countdown läuft …');
          stopInterval();
          intervalId = setInterval(tick, 1000);
        };

        const pause = () => {
          if (!running) return;
          stopInterval();
          running = false;
          setInputsDisabled(false);
          setMsg('Pausiert – mit Start fortsetzen.');
        };

        const reset = () => {
          stopInterval();
          running = false;
          remaining = 0;
          render();
          setInputsDisabled(false);
          setMsg('Zurückgesetzt. Stelle eine Zeit ein und starte erneut.');
        };

        startBtn.addEventListener('click', start);
        pauseBtn.addEventListener('click', pause);
        resetBtn.addEventListener('click', reset);

        // Anzeige aus den Standardwerten initialisieren (ohne den Timer zu starten).
        remaining = readInputs();
        render();
        remaining = 0; // nicht als laufende Restzeit übernehmen – Start lädt neu.
      }
    }
  </script>
</BaseLayout>
