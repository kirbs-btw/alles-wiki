---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('bingo-zahlen-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
        <label class="block w-full sm:w-auto">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Zahlenbereich</span>
          <select
            id="bingo-range"
            class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2.5 text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300 sm:w-auto"
          >
            <option value="75">1–75 (US-Bingo)</option>
            <option value="90">1–90 (klassisch)</option>
          </select>
        </label>
        <div class="flex flex-wrap gap-2">
          <button id="bingo-next" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Nächste Zahl</button>
          <button id="bingo-all" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-4 py-2.5 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Alle ziehen</button>
          <button id="bingo-reset" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-4 py-2.5 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Neu</button>
        </div>
      </div>

      <div class="mt-6 flex flex-col items-center justify-center rounded-lg border border-zinc-200 bg-zinc-50 py-8">
        <span class="text-xs font-medium uppercase tracking-wide text-zinc-500">Aktuelle Zahl</span>
        <span id="bingo-current" aria-live="polite" class="mt-1 font-mono text-6xl font-extrabold text-brand-700">–</span>
      </div>

      <div class="mt-6">
        <div class="flex items-center justify-between">
          <span class="text-sm font-medium text-zinc-700">Gezogene Zahlen</span>
          <span id="bingo-count" class="font-mono text-xs text-zinc-500">0 / 75</span>
        </div>
        <div id="bingo-list" class="mt-2 flex min-h-[2.5rem] flex-wrap gap-2 rounded-lg border border-zinc-200 bg-white p-3"></div>
      </div>

      <p id="bingo-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Klicke „Nächste Zahl", um eine Bingo-Zahl zu ziehen.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const rangeEl = document.getElementById('bingo-range') as HTMLSelectElement | null;
      const currentEl = document.getElementById('bingo-current') as HTMLElement | null;
      const listEl = document.getElementById('bingo-list') as HTMLElement | null;
      const countEl = document.getElementById('bingo-count') as HTMLElement | null;
      const msgEl = document.getElementById('bingo-msg') as HTMLElement | null;
      const nextBtn = document.getElementById('bingo-next') as HTMLButtonElement | null;
      const allBtn = document.getElementById('bingo-all') as HTMLButtonElement | null;
      const resetBtn = document.getElementById('bingo-reset') as HTMLButtonElement | null;

      if (rangeEl && currentEl && listEl && countEl && msgEl) {
        // Unverzerrter Zufallsindex via Rejection-Sampling (vermeidet Modulo-Bias).
        const randIndex = (mod: number) => {
          if (mod <= 0) return 0;
          const limit = Math.floor(2 ** 32 / mod) * mod;
          const buf = new Uint32Array(1);
          let v: number;
          do {
            crypto.getRandomValues(buf);
            v = buf[0];
          } while (v >= limit);
          return v % mod;
        };

        let max = 75;
        let remaining: number[] = []; // noch nicht gezogene Zahlen
        let drawn: number[] = []; // bereits gezogene Zahlen

        const reset = () => {
          const parsed = parseInt(rangeEl.value, 10);
          max = parsed === 90 ? 90 : 75;
          remaining = [];
          for (let n = 1; n <= max; n++) remaining.push(n);
          drawn = [];
          currentEl.textContent = '–';
          renderList();
          updateCount();
          msgEl.textContent = 'Klicke „Nächste Zahl", um eine Bingo-Zahl zu ziehen.';
        };

        const renderList = () => {
          listEl.textContent = '';
          if (drawn.length === 0) return;
          const sorted = [...drawn].sort((a, b) => a - b);
          for (const n of sorted) {
            const chip = document.createElement('span');
            chip.className =
              'inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-50 font-mono text-sm font-semibold text-brand-700 ring-1 ring-brand-200';
            chip.textContent = String(n);
            listEl.appendChild(chip);
          }
        };

        const updateCount = () => {
          countEl.textContent = `${drawn.length} / ${max}`;
        };

        const drawOne = (): number | null => {
          if (remaining.length === 0) return null;
          const idx = randIndex(remaining.length);
          const [n] = remaining.splice(idx, 1);
          drawn.push(n);
          return n;
        };

        const drawNext = () => {
          const n = drawOne();
          if (n === null) {
            msgEl.textContent = 'Alle Zahlen wurden gezogen. Klicke „Neu" für eine neue Runde.';
            return;
          }
          currentEl.textContent = String(n);
          renderList();
          updateCount();
          if (remaining.length === 0) {
            msgEl.textContent = 'Alle Zahlen wurden gezogen. Klicke „Neu" für eine neue Runde.';
          } else {
            msgEl.textContent = `Gezogen: ${n}. Noch ${remaining.length} Zahlen übrig.`;
          }
        };

        const drawAll = () => {
          if (remaining.length === 0) {
            msgEl.textContent = 'Alle Zahlen wurden bereits gezogen. Klicke „Neu" für eine neue Runde.';
            return;
          }
          let last: number | null = null;
          // Anzahl gedeckelt durch die Größe von remaining (max. 90).
          while (remaining.length > 0) {
            last = drawOne();
          }
          if (last !== null) currentEl.textContent = String(last);
          renderList();
          updateCount();
          msgEl.textContent = 'Alle Zahlen wurden gezogen. Klicke „Neu" für eine neue Runde.';
        };

        nextBtn?.addEventListener('click', drawNext);
        allBtn?.addEventListener('click', drawAll);
        resetBtn?.addEventListener('click', reset);
        rangeEl.addEventListener('change', reset);

        reset();
      }
    }
  </script>
</BaseLayout>
