---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('json-formatter')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-5 lg:grid-cols-2">
        <div class="flex flex-col">
          <label class="mb-1 block text-sm font-medium text-zinc-700" for="json-in">JSON-Eingabe</label>
          <textarea
            id="json-in"
            rows="12"
            spellcheck="false"
            placeholder={'{ "name": "Beispiel", "werte": [1, 2, 3] }'}
            class="w-full resize-y rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 font-mono text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          ></textarea>
        </div>
        <div class="flex flex-col">
          <div class="mb-1 flex items-center justify-between">
            <label class="block text-sm font-medium text-zinc-700" for="json-out">Ergebnis</label>
            <button id="json-copy" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-3 py-1.5 text-xs font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Kopieren</button>
          </div>
          <textarea
            id="json-out"
            rows="12"
            readonly
            spellcheck="false"
            class="w-full resize-y rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 font-mono text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          ></textarea>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        <button id="json-format" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Formatieren</button>
        <button id="json-minify" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Minifizieren</button>
        <button id="json-clear" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-4 py-2.5 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Leeren</button>
      </div>

      <p id="json-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Füge JSON ein und wähle „Formatieren" oder „Minifizieren". Alles läuft lokal in deinem Browser – nichts wird übertragen.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const input = document.getElementById('json-in') as HTMLTextAreaElement | null;
      const output = document.getElementById('json-out') as HTMLTextAreaElement | null;
      const msg = document.getElementById('json-msg') as HTMLElement | null;
      const formatBtn = document.getElementById('json-format');
      const minifyBtn = document.getElementById('json-minify');
      const clearBtn = document.getElementById('json-clear');
      const copyBtn = document.getElementById('json-copy');

      const defaultMsg = 'Füge JSON ein und wähle „Formatieren" oder „Minifizieren". Alles läuft lokal in deinem Browser – nichts wird übertragen.';

      const setMsg = (text: string) => { if (msg) msg.textContent = text; };

      const process = (pretty: boolean) => {
        if (!input || !output) return;
        const raw = input.value.trim();
        if (!raw) {
          output.value = '';
          setMsg('Bitte zuerst JSON in das Eingabefeld einfügen.');
          return;
        }
        let parsed: unknown;
        try {
          parsed = JSON.parse(raw);
        } catch (e) {
          output.value = '';
          const detail = e instanceof Error ? e.message : String(e);
          setMsg('Ungültiges JSON: ' + detail);
          return;
        }
        try {
          output.value = pretty ? JSON.stringify(parsed, null, 2) : JSON.stringify(parsed);
          setMsg(pretty ? 'JSON erfolgreich formatiert.' : 'JSON erfolgreich minifiziert.');
        } catch (e) {
          output.value = '';
          const detail = e instanceof Error ? e.message : String(e);
          setMsg('Fehler beim Erzeugen der Ausgabe: ' + detail);
        }
      };

      formatBtn?.addEventListener('click', () => process(true));
      minifyBtn?.addEventListener('click', () => process(false));

      clearBtn?.addEventListener('click', () => {
        if (input) input.value = '';
        if (output) output.value = '';
        setMsg(defaultMsg);
      });

      copyBtn?.addEventListener('click', async () => {
        if (!output || !output.value) { setMsg('Es gibt noch kein Ergebnis zum Kopieren.'); return; }
        try {
          await navigator.clipboard.writeText(output.value);
          setMsg('Ergebnis kopiert.');
        } catch {
          output.select();
          setMsg('Markiert – mit Strg/Cmd+C kopieren.');
        }
      });
    }
  </script>
</BaseLayout>
