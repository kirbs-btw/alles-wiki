---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('lorem-ipsum-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Anzahl</span>
          <input
            id="li-count"
            type="number"
            min="1"
            max="50"
            value="3"
            step="1"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Einheit</span>
          <select
            id="li-unit"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          >
            <option value="paragraphs">Absätze</option>
            <option value="sentences">Sätze</option>
            <option value="words">Wörter</option>
          </select>
        </label>
      </div>

      <label class="mt-4 flex items-center gap-2 text-sm text-zinc-700">
        <input id="li-classic" type="checkbox" checked class="accent-brand-700" />
        Mit „Lorem ipsum dolor sit amet" beginnen
      </label>

      <div class="mt-5 flex flex-wrap gap-2">
        <button id="li-gen" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Generieren</button>
        <button id="li-copy" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-4 py-2.5 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Kopieren</button>
      </div>

      <label class="mt-5 block">
        <span class="sr-only">Generierter Blindtext</span>
        <textarea
          id="li-out"
          readonly
          rows="10"
          aria-live="polite"
          class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 text-sm leading-relaxed text-zinc-900 shadow-sm outline-none"
        ></textarea>
      </label>
      <p id="li-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Generiert lokal in deinem Browser – nichts wird übertragen.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const countEl = document.getElementById('li-count') as HTMLInputElement | null;
      const unitEl = document.getElementById('li-unit') as HTMLSelectElement | null;
      const classicEl = document.getElementById('li-classic') as HTMLInputElement | null;
      const out = document.getElementById('li-out') as HTMLTextAreaElement | null;
      const msg = document.getElementById('li-msg') as HTMLElement | null;
      const genBtn = document.getElementById('li-gen');
      const copyBtn = document.getElementById('li-copy');

      if (countEl && unitEl && classicEl && out && msg) {
        const WORDS = [
          'lorem', 'ipsum', 'dolor', 'sit', 'amet', 'consectetur', 'adipiscing', 'elit',
          'sed', 'do', 'eiusmod', 'tempor', 'incididunt', 'ut', 'labore', 'et', 'dolore',
          'magna', 'aliqua', 'enim', 'ad', 'minim', 'veniam', 'quis', 'nostrud',
          'exercitation', 'ullamco', 'laboris', 'nisi', 'aliquip', 'ex', 'ea', 'commodo',
          'consequat', 'duis', 'aute', 'irure', 'in', 'reprehenderit', 'voluptate',
          'velit', 'esse', 'cillum', 'eu', 'fugiat', 'nulla', 'pariatur', 'excepteur',
          'sint', 'occaecat', 'cupidatat', 'non', 'proident', 'sunt', 'culpa', 'qui',
          'officia', 'deserunt', 'mollit', 'anim', 'id', 'est', 'laborum', 'at', 'vero',
          'eos', 'accusamus', 'iusto', 'odio', 'dignissimos', 'ducimus', 'blanditiis',
          'praesentium', 'voluptatum', 'deleniti', 'atque', 'corrupti', 'quos', 'dolores',
          'quas', 'molestias', 'excepturi', 'occaecati', 'cupiditate', 'similique',
          'mollitia', 'animi', 'dolorum', 'fuga', 'harum', 'quidem', 'rerum', 'facilis',
        ];
        const CLASSIC_START = ['lorem', 'ipsum', 'dolor', 'sit', 'amet'];

        const randInt = (min: number, max: number) =>
          Math.floor(Math.random() * (max - min + 1)) + min;
        const pickWord = () => WORDS[randInt(0, WORDS.length - 1)];

        const capitalize = (w: string) => w.charAt(0).toUpperCase() + w.slice(1);

        const makeSentence = (start?: string[]) => {
          const len = randInt(6, 12);
          const words: string[] = [];
          if (start) {
            for (const w of start) words.push(w);
          }
          while (words.length < len) words.push(pickWord());
          const text = words.join(' ');
          return capitalize(text) + '.';
        };

        const makeParagraph = (firstSentenceStart?: string[]) => {
          const sentences = randInt(3, 6);
          const arr: string[] = [];
          for (let i = 0; i < sentences; i++) {
            arr.push(makeSentence(i === 0 ? firstSentenceStart : undefined));
          }
          return arr.join(' ');
        };

        const clampCount = () => {
          let n = parseInt(countEl.value, 10);
          if (!Number.isFinite(n) || n < 1) n = 1;
          if (n > 50) n = 50;
          return n;
        };

        const generate = () => {
          const n = clampCount();
          const unit = unitEl.value;
          const classic = classicEl.checked;
          let result = '';

          if (unit === 'words') {
            const words: string[] = [];
            for (let i = 0; i < n; i++) {
              if (classic && i < CLASSIC_START.length) {
                words.push(CLASSIC_START[i]);
              } else {
                words.push(pickWord());
              }
            }
            result = capitalize(words.join(' '));
          } else if (unit === 'sentences') {
            const arr: string[] = [];
            for (let i = 0; i < n; i++) {
              arr.push(makeSentence(i === 0 && classic ? CLASSIC_START : undefined));
            }
            result = arr.join(' ');
          } else {
            const arr: string[] = [];
            for (let i = 0; i < n; i++) {
              arr.push(makeParagraph(i === 0 && classic ? CLASSIC_START : undefined));
            }
            result = arr.join('\n\n');
          }

          out.value = result;
          msg.textContent = 'Generiert lokal in deinem Browser – nichts wird übertragen.';
        };

        genBtn?.addEventListener('click', generate);
        copyBtn?.addEventListener('click', async () => {
          if (!out.value) return;
          try {
            await navigator.clipboard.writeText(out.value);
            msg.textContent = 'Text kopiert.';
          } catch {
            out.select();
            msg.textContent = 'Markiert – mit Strg/Cmd+C kopieren.';
          }
        });

        generate();
      }
    }
  </script>
</BaseLayout>
