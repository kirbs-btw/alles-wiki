---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('benutzername-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-5 sm:grid-cols-3">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Anzahl Vorschläge</span>
          <input
            id="un-count"
            type="number"
            min="1"
            max="50"
            value="8"
            step="1"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Trennzeichen</span>
          <select
            id="un-sep"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          >
            <option value="">kein</option>
            <option value="_">Unterstrich (_)</option>
            <option value=".">Punkt (.)</option>
          </select>
        </label>
        <div class="flex items-end">
          <label class="flex items-center gap-2 text-sm text-zinc-700">
            <input id="un-numbers" type="checkbox" checked class="accent-brand-700" /> Zahlen anhängen
          </label>
        </div>
      </div>

      <div class="mt-5">
        <button
          id="un-gen"
          type="button"
          class="w-full rounded-lg bg-brand-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300 sm:w-auto"
        >Generieren</button>
      </div>

      <ul id="un-list" class="mt-6 grid gap-2 sm:grid-cols-2" aria-live="polite"></ul>

      <p id="un-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Wird lokal in deinem Browser erzeugt – nichts wird übertragen.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const countEl = document.getElementById('un-count') as HTMLInputElement | null;
      const sepEl = document.getElementById('un-sep') as HTMLSelectElement | null;
      const numbersEl = document.getElementById('un-numbers') as HTMLInputElement | null;
      const genBtn = document.getElementById('un-gen') as HTMLButtonElement | null;
      const list = document.getElementById('un-list') as HTMLElement | null;
      const msg = document.getElementById('un-msg') as HTMLElement | null;

      if (countEl && sepEl && numbersEl && genBtn && list && msg) {
        const adjektive = [
          'flink', 'mutig', 'leise', 'wild', 'schlau', 'kühn', 'frech', 'ruhig',
          'tapfer', 'munter', 'edel', 'fix', 'klug', 'stark', 'sanft', 'keck',
          'hell', 'dunkel', 'froh', 'eisig', 'golden', 'silbern', 'wirbelnd', 'weise',
        ];
        const nomen = [
          'Fuchs', 'Komet', 'Nebel', 'Tiger', 'Pixel', 'Drache', 'Falke', 'Wolf',
          'Sturm', 'Phönix', 'Raabe', 'Luchs', 'Adler', 'Panther', 'Kobold', 'Bär',
          'Geist', 'Schatten', 'Funke', 'Blitz', 'Krieger', 'Jäger', 'Wächter', 'Ritter',
        ];

        const MAX_COUNT = 50;

        // Unverzerrter Zufallsindex via Rejection-Sampling (vermeidet Modulo-Bias).
        const randIndex = (mod: number) => {
          if (mod <= 0) return 0;
          const limit = Math.floor(2 ** 32 / mod) * mod;
          const buf = new Uint32Array(1);
          let v: number;
          do {
            crypto.getRandomValues(buf);
            v = buf[0];
          } while (v >= limit);
          return v % mod;
        };

        const pick = (arr: string[]) => arr[randIndex(arr.length)];

        const copyTo = async (text: string, btn: HTMLButtonElement) => {
          try {
            await navigator.clipboard.writeText(text);
            const prev = btn.textContent;
            btn.textContent = 'Kopiert';
            msg.textContent = `„${text}" kopiert.`;
            window.setTimeout(() => { btn.textContent = prev; }, 1200);
          } catch {
            btn.classList.add('ring-2', 'ring-brand-300');
            msg.textContent = `Kopieren nicht möglich – „${text}" manuell markieren.`;
          }
        };

        const buildName = (withNumbers: boolean, sep: string) => {
          const adj = pick(adjektive);
          const nom = pick(nomen);
          let name = adj + sep + nom;
          if (withNumbers) {
            // 2- bis 3-stellige Zahl (10–999).
            const num = 10 + randIndex(990);
            name = name + sep + String(num);
          }
          return name;
        };

        const generate = () => {
          let count = parseInt(countEl.value, 10);
          if (!Number.isFinite(count) || count < 1) {
            msg.textContent = 'Bitte eine Anzahl zwischen 1 und 50 eingeben.';
            list.innerHTML = '';
            return;
          }
          if (count > MAX_COUNT) {
            count = MAX_COUNT;
            countEl.value = String(MAX_COUNT);
          }

          const withNumbers = numbersEl.checked;
          const sep = sepEl.value;

          const seen = new Set<string>();
          const names: string[] = [];
          // Deckelung der Versuche, damit nichts hängt, falls Kombinationen knapp werden.
          const maxAttempts = count * 40;
          let attempts = 0;
          while (names.length < count && attempts < maxAttempts) {
            attempts++;
            const name = buildName(withNumbers, sep);
            if (seen.has(name)) continue;
            seen.add(name);
            names.push(name);
          }

          if (names.length === 0) {
            msg.textContent = 'Es konnten keine Vorschläge erzeugt werden. Bitte erneut versuchen.';
            list.innerHTML = '';
            return;
          }

          list.innerHTML = '';
          for (const name of names) {
            const li = document.createElement('li');
            li.className = 'flex items-center justify-between gap-3 rounded-lg border border-zinc-200 bg-zinc-50 px-3 py-2';

            const span = document.createElement('span');
            span.className = 'truncate font-mono text-sm text-zinc-900';
            span.textContent = name;

            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'shrink-0 rounded-md border border-zinc-300 px-3 py-1 text-xs font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300';
            btn.textContent = 'Kopieren';
            btn.addEventListener('click', () => { copyTo(name, btn); });

            li.appendChild(span);
            li.appendChild(btn);
            list.appendChild(li);
          }

          msg.textContent = withNumbers
            ? `${names.length} Vorschlag${names.length === 1 ? '' : 'e'} erzeugt – mit angehängten Zahlen.`
            : `${names.length} Vorschlag${names.length === 1 ? '' : 'e'} erzeugt.`;
        };

        genBtn.addEventListener('click', generate);
        generate();
      }
    }
  </script>
</BaseLayout>
