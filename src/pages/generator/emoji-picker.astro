              document.body.removeChild(ta);
              msg.textContent = `${emoji} kopiert.`;
            } catch {
              msg.textContent = `${emoji} – Kopieren nicht möglich, bitte manuell markieren.`;
            }
          }
        };

        const render = () => {
          const q = search.value.trim().toLowerCase();
          const matches = EMOJIS.filter((e) => {
            const inCat = activeCat === 'Alle' || e.cat === activeCat;
            if (!inCat) return false;
            if (!q) return true;
            return e.k.some((word) => word.includes(q)) || e.cat.toLowerCase().includes(q);
          });
          // Anzahl deckeln (Sicherheitsnetz, Liste ist ohnehin klein).
          const shown = matches.slice(0, 300);
          gridEl.innerHTML = '';
          if (shown.length === 0) {
            msg.textContent = 'Kein passendes Emoji gefunden.';
            return;
          }
          const frag = document.createDocumentFragment();
          for (const e of shown) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.textContent = e.c;
            btn.setAttribute('role', 'listitem');
            btn.setAttribute('title', e.k[0] ?? e.cat);
            btn.setAttribute('aria-label', `${e.k[0] ?? 'Emoji'} kopieren`);
            btn.className =
              'flex aspect-square items-center justify-center rounded-lg border border-zinc-200 bg-zinc-50 text-2xl transition hover:-translate-y-0.5 hover:border-brand-300 hover:bg-white hover:shadow-md focus-visible:ring-2 focus-visible:ring-brand-300';
            btn.addEventListener('click', () => copyEmoji(e.c));
            frag.appendChild(btn);
          }
          gridEl.appendChild(frag);
          msg.textContent = 'Klicke ein Emoji, um es zu kopieren.';
        };

        // Kategorie-Buttons aufbauen.
        const catButtons: HTMLButtonElement[] = [];
        const styleCatButtons = () => {
          for (const b of catButtons) {
            const isActive = b.dataset.cat === activeCat;
            b.className = isActive
              ? 'rounded-full bg-brand-700 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300'
              : 'rounded-full border border-zinc-300 px-3 py-1.5 text-sm font-medium text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300';
            b.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          }
        };
        for (const cat of CATS) {
          const b = document.createElement('button');
          b.type = 'button';
          b.textContent = cat;
          b.dataset.cat = cat;
          b.addEventListener('click', () => {
            activeCat = cat;
            styleCatButtons();
            render();
          });
          catButtons.push(b);
          catsEl.appendChild(b);
        }
        styleCatButtons();

        search.addEventListener('input', render);
        render();
      }
    }
  </script>
</BaseLayout>
