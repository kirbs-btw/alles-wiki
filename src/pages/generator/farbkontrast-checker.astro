---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('farbkontrast-checker')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label class="mb-1 block text-sm font-medium text-zinc-700" for="kontrast-fg-hex">Textfarbe</label>
          <div class="flex gap-2">
            <input
              id="kontrast-fg-color"
              type="color"
              value="#111827"
              aria-label="Textfarbe wählen"
              class="h-11 w-14 shrink-0 cursor-pointer rounded-lg border border-zinc-300 bg-white p-1 shadow-sm focus-visible:ring-2 focus-visible:ring-brand-300"
            />
            <input
              id="kontrast-fg-hex"
              type="text"
              value="#111827"
              spellcheck="false"
              autocomplete="off"
              maxlength="7"
              class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 font-mono text-sm uppercase text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
            />
          </div>
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-zinc-700" for="kontrast-bg-hex">Hintergrundfarbe</label>
          <div class="flex gap-2">
            <input
              id="kontrast-bg-color"
              type="color"
              value="#ffffff"
              aria-label="Hintergrundfarbe wählen"
              class="h-11 w-14 shrink-0 cursor-pointer rounded-lg border border-zinc-300 bg-white p-1 shadow-sm focus-visible:ring-2 focus-visible:ring-brand-300"
            />
            <input
              id="kontrast-bg-hex"
              type="text"
              value="#ffffff"
              spellcheck="false"
              autocomplete="off"
              maxlength="7"
              class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2 font-mono text-sm uppercase text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
            />
          </div>
        </div>
      </div>

      <!-- Live-Vorschau -->
      <div
        id="kontrast-preview"
        class="mt-6 rounded-lg border border-zinc-200 p-6 shadow-inner"
        style="background-color:#ffffff;color:#111827"
      >
        <p class="text-lg font-semibold">Normaler Text – so liest sich der Inhalt.</p>
        <p class="mt-1 text-2xl font-bold">Großer Text – Überschrift</p>
      </div>

      <!-- Ergebnis -->
      <div class="mt-6 flex flex-col items-start gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-medium text-zinc-700">Kontrastverhältnis</p>
          <p id="kontrast-ratio" class="text-3xl font-extrabold tracking-tight text-zinc-900" aria-live="polite">–</p>
        </div>
        <button
          id="kontrast-copy"
          type="button"
          class="shrink-0 rounded-lg border border-zinc-300 px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300"
        >Verhältnis kopieren</button>
      </div>

      <!-- Bewertungen -->
      <dl class="mt-5 grid gap-3 sm:grid-cols-2">
        <div class="flex items-center justify-between rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3">
          <dt class="text-sm text-zinc-700">AA – normaler Text (≥ 4,5:1)</dt>
          <dd id="kontrast-aa-normal" class="text-sm font-semibold text-zinc-500">–</dd>
        </div>
        <div class="flex items-center justify-between rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3">
          <dt class="text-sm text-zinc-700">AA – großer Text (≥ 3:1)</dt>
          <dd id="kontrast-aa-large" class="text-sm font-semibold text-zinc-500">–</dd>
        </div>
        <div class="flex items-center justify-between rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3">
          <dt class="text-sm text-zinc-700">AAA – normaler Text (≥ 7:1)</dt>
          <dd id="kontrast-aaa-normal" class="text-sm font-semibold text-zinc-500">–</dd>
        </div>
        <div class="flex items-center justify-between rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3">
          <dt class="text-sm text-zinc-700">AAA – großer Text (≥ 4,5:1)</dt>
          <dd id="kontrast-aaa-large" class="text-sm font-semibold text-zinc-500">–</dd>
        </div>
      </dl>

      <p id="kontrast-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Wähle Text- und Hintergrundfarbe – die Bewertung aktualisiert sich automatisch.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const fgColor = document.getElementById('kontrast-fg-color') as HTMLInputElement | null;
      const fgHex = document.getElementById('kontrast-fg-hex') as HTMLInputElement | null;
      const bgColor = document.getElementById('kontrast-bg-color') as HTMLInputElement | null;
      const bgHex = document.getElementById('kontrast-bg-hex') as HTMLInputElement | null;
      const preview = document.getElementById('kontrast-preview') as HTMLElement | null;
      const ratioEl = document.getElementById('kontrast-ratio') as HTMLElement | null;
      const aaNormal = document.getElementById('kontrast-aa-normal') as HTMLElement | null;
      const aaLarge = document.getElementById('kontrast-aa-large') as HTMLElement | null;
      const aaaNormal = document.getElementById('kontrast-aaa-normal') as HTMLElement | null;
      const aaaLarge = document.getElementById('kontrast-aaa-large') as HTMLElement | null;
      const copyBtn = document.getElementById('kontrast-copy') as HTMLButtonElement | null;
      const msg = document.getElementById('kontrast-msg') as HTMLElement | null;

      // HEX (#rgb oder #rrggbb) -> {r,g,b} in 0..255, sonst null.
      const parseHex = (raw: string): { r: number; g: number; b: number } | null => {
        let h = (raw || '').trim().replace(/^#/, '');
        if (/^[0-9a-fA-F]{3}$/.test(h)) {
          h = h[0] + h[0] + h[1] + h[1] + h[2] + h[2];
        }
        if (!/^[0-9a-fA-F]{6}$/.test(h)) return null;
        return {
          r: parseInt(h.slice(0, 2), 16),
          g: parseInt(h.slice(2, 4), 16),
          b: parseInt(h.slice(4, 6), 16),
        };
      };

      // Relative Luminanz nach WCAG: sRGB linearisieren, dann gewichten.
      const luminance = (c: { r: number; g: number; b: number }): number => {
        const lin = (v: number) => {
          const s = v / 255;
          return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4);
        };
        return 0.2126 * lin(c.r) + 0.7152 * lin(c.g) + 0.0722 * lin(c.b);
      };

      const setBadge = (el: HTMLElement | null, passed: boolean) => {
        if (!el) return;
        el.textContent = passed ? 'bestanden' : 'nicht bestanden';
        el.className = passed
          ? 'text-sm font-semibold text-green-700'
          : 'text-sm font-semibold text-red-600';
      };

      const update = () => {
        if (!fgHex || !bgHex) return;
        const fg = parseHex(fgHex.value);
        const bg = parseHex(bgHex.value);

        if (!fg || !bg) {
          if (ratioEl) ratioEl.textContent = '–';
          [aaNormal, aaLarge, aaaNormal, aaaLarge].forEach((el) => {
            if (el) {
              el.textContent = '–';
              el.className = 'text-sm font-semibold text-zinc-500';
            }
          });
          if (msg) msg.textContent = 'Bitte eine gültige HEX-Farbe eingeben (z. B. #1a2b3c).';
          return;
        }

        const l1 = luminance(fg);
        const l2 = luminance(bg);
        const lighter = Math.max(l1, l2);
        const darker = Math.min(l1, l2);
        const ratio = (lighter + 0.05) / (darker + 0.05);

        if (ratioEl) ratioEl.textContent = ratio.toFixed(2) + ':1';

        setBadge(aaNormal, ratio >= 4.5);
        setBadge(aaLarge, ratio >= 3);
        setBadge(aaaNormal, ratio >= 7);
        setBadge(aaaLarge, ratio >= 4.5);

        if (preview) {
          const toHex = (c: { r: number; g: number; b: number }) =>
            '#' + [c.r, c.g, c.b].map((v) => v.toString(16).padStart(2, '0')).join('');
          preview.style.color = toHex(fg);
          preview.style.backgroundColor = toHex(bg);
        }

        if (msg) msg.textContent = 'Wähle Text- und Hintergrundfarbe – die Bewertung aktualisiert sich automatisch.';
      };

      // Color-Picker -> HEX-Feld synchronisieren.
      const syncFromPicker = (picker: HTMLInputElement | null, hex: HTMLInputElement | null) => {
        if (!picker || !hex) return;
        hex.value = picker.value.toUpperCase();
        update();
      };
      // HEX-Feld -> Color-Picker synchronisieren (nur bei gültigem Wert).
      const syncFromHex = (hex: HTMLInputElement | null, picker: HTMLInputElement | null) => {
        if (!hex || !picker) return;
        const c = parseHex(hex.value);
        if (c) {
          const toHex = '#' + [c.r, c.g, c.b].map((v) => v.toString(16).padStart(2, '0')).join('');
          picker.value = toHex;
        }
        update();
      };

      fgColor?.addEventListener('input', () => syncFromPicker(fgColor, fgHex));
      bgColor?.addEventListener('input', () => syncFromPicker(bgColor, bgHex));
      fgHex?.addEventListener('input', () => syncFromHex(fgHex, fgColor));
      bgHex?.addEventListener('input', () => syncFromHex(bgHex, bgColor));

      copyBtn?.addEventListener('click', async () => {
        if (!ratioEl || ratioEl.textContent === '–') return;
        const text = ratioEl.textContent || '';
        try {
          await navigator.clipboard.writeText(text);
          if (msg) msg.textContent = 'Kontrastverhältnis kopiert.';
        } catch {
          if (msg) msg.textContent = 'Kopieren nicht möglich – Wert: ' + text;
        }
      });

      update();
    }
  </script>
</BaseLayout>
