---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('uuid-generator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Anzahl</span>
          <input
            id="uuid-count"
            type="number"
            min="1"
            max="1000"
            value="5"
            step="1"
            class="w-32 rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 font-mono text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
        <div class="flex gap-2">
          <button id="uuid-gen" type="button" class="shrink-0 rounded-lg bg-brand-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Generieren</button>
          <button id="uuid-copy" type="button" class="shrink-0 rounded-lg border border-zinc-300 px-4 py-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Alle kopieren</button>
        </div>
      </div>

      <div class="mt-6">
        <label class="sr-only" for="uuid-out">Generierte UUIDs</label>
        <textarea
          id="uuid-out"
          readonly
          rows="6"
          class="w-full resize-y rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-3 font-mono text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
        ></textarea>
      </div>

      <p id="uuid-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Generiert lokal in deinem Browser – nichts wird übertragen.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const countEl = document.getElementById('uuid-count') as HTMLInputElement | null;
      const out = document.getElementById('uuid-out') as HTMLTextAreaElement | null;
      const msg = document.getElementById('uuid-msg') as HTMLElement | null;
      const genBtn = document.getElementById('uuid-gen');
      const copyBtn = document.getElementById('uuid-copy');

      const MAX = 1000;
      const hexChars = '0123456789abcdef';

      // Eine zufällige v4-UUID erzeugen. Nutzt crypto.randomUUID, falls vorhanden;
      // andernfalls Fallback über crypto.getRandomValues mit korrekten v4-Bits.
      const makeUuid = (): string => {
        try {
          if (typeof crypto !== 'undefined' && typeof (crypto as Crypto).randomUUID === 'function') {
            return crypto.randomUUID();
          }
        } catch {
          // weiter zum Fallback
        }
        const bytes = new Uint8Array(16);
        crypto.getRandomValues(bytes);
        // Version 4: oberen 4 Bit von Byte 6 auf 0100 setzen.
        bytes[6] = (bytes[6] & 0x0f) | 0x40;
        // Variant 10xx: oberen 2 Bit von Byte 8 auf 10 setzen.
        bytes[8] = (bytes[8] & 0x3f) | 0x80;
        let hex = '';
        for (let i = 0; i < 16; i++) {
          hex += hexChars[bytes[i] >> 4] + hexChars[bytes[i] & 0x0f];
        }
        return (
          hex.slice(0, 8) + '-' +
          hex.slice(8, 12) + '-' +
          hex.slice(12, 16) + '-' +
          hex.slice(16, 20) + '-' +
          hex.slice(20, 32)
        );
      };

      const generate = () => {
        if (!countEl || !out || !msg) return;
        const raw = parseInt(countEl.value, 10);
        if (!Number.isFinite(raw) || raw < 1) {
          out.value = '';
          msg.textContent = 'Bitte eine Anzahl von mindestens 1 eingeben.';
          return;
        }
        const count = Math.min(Math.floor(raw), MAX);
        const list: string[] = [];
        for (let i = 0; i < count; i++) list.push(makeUuid());
        out.value = list.join('\n');
        if (raw > MAX) {
          msg.textContent = `Auf ${MAX} UUIDs begrenzt – ${count} erzeugt.`;
        } else {
          msg.textContent = count === 1 ? '1 UUID erzeugt.' : `${count} UUIDs erzeugt.`;
        }
      };

      genBtn?.addEventListener('click', generate);

      copyBtn?.addEventListener('click', async () => {
        if (!out || !msg) return;
        if (!out.value) {
          msg.textContent = 'Noch nichts zum Kopieren – bitte erst generieren.';
          return;
        }
        try {
          await navigator.clipboard.writeText(out.value);
          msg.textContent = 'Alle UUIDs kopiert.';
        } catch {
          out.select();
          msg.textContent = 'Markiert – mit Strg/Cmd+C kopieren.';
        }
      });

      generate();
    }
  </script>
</BaseLayout>
