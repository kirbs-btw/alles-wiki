---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('stoppuhr')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="flex flex-col items-center">
        <div
          id="stoppuhr-anzeige"
          role="timer"
          aria-live="polite"
          aria-label="Verstrichene Zeit"
          class="font-mono text-5xl font-bold tabular-nums tracking-tight text-zinc-900 sm:text-7xl"
        >00:00.00</div>

        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          <button id="stoppuhr-start" type="button" class="rounded-lg bg-brand-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300">Start</button>
          <button id="stoppuhr-stopp" type="button" disabled class="rounded-lg bg-brand-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300 disabled:cursor-not-allowed disabled:opacity-40">Stopp</button>
          <button id="stoppuhr-runde" type="button" disabled class="rounded-lg border border-zinc-300 px-5 py-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300 disabled:cursor-not-allowed disabled:opacity-40">Runde</button>
          <button id="stoppuhr-reset" type="button" class="rounded-lg border border-zinc-300 px-5 py-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300">Zurücksetzen</button>
        </div>
      </div>

      <div id="stoppuhr-runden-box" class="mt-6 hidden">
        <h2 class="text-sm font-semibold text-zinc-700">Rundenzeiten</h2>
        <ol id="stoppuhr-runden" class="mt-2 divide-y divide-zinc-100 overflow-hidden rounded-lg border border-zinc-200"></ol>
      </div>

      <p id="stoppuhr-msg" class="mt-4 text-xs text-zinc-500" aria-live="polite">Läuft komplett lokal in deinem Browser – nichts wird übertragen.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const anzeige = document.getElementById('stoppuhr-anzeige');
      const startBtn = document.getElementById('stoppuhr-start') as HTMLButtonElement | null;
      const stoppBtn = document.getElementById('stoppuhr-stopp') as HTMLButtonElement | null;
      const rundeBtn = document.getElementById('stoppuhr-runde') as HTMLButtonElement | null;
      const resetBtn = document.getElementById('stoppuhr-reset') as HTMLButtonElement | null;
      const rundenBox = document.getElementById('stoppuhr-runden-box');
      const rundenListe = document.getElementById('stoppuhr-runden');
      const msg = document.getElementById('stoppuhr-msg');

      if (anzeige && startBtn && stoppBtn && rundeBtn && resetBtn && rundenBox && rundenListe && msg) {
        const MAX_RUNDEN = 200;
        let laufend = false;
        let startZeit = 0;       // performance.now() beim (Wieder-)Start
        let angesammelt = 0;     // bereits gestoppte Millisekunden
        let rafId = 0;
        let letzteRunde = 0;     // verstrichene Zeit beim letzten Runden-Klick (ms)
        let rundenNr = 0;

        const verstrichen = () => angesammelt + (laufend ? performance.now() - startZeit : 0);

        // Millisekunden -> MM:SS.cc (Hundertstel). Bei sehr langen Zeiten wachsen die Minuten.
        const formatieren = (ms: number) => {
          if (!isFinite(ms) || ms < 0) ms = 0;
          const hundertstel = Math.floor(ms / 10) % 100;
          const sekunden = Math.floor(ms / 1000) % 60;
          const minuten = Math.floor(ms / 60000);
          const z = (n: number) => String(n).padStart(2, '0');
          return `${z(minuten)}:${z(sekunden)}.${z(hundertstel)}`;
        };

        const anzeigen = () => { anzeige.textContent = formatieren(verstrichen()); };

        const ticken = () => {
          anzeigen();
          if (laufend) rafId = requestAnimationFrame(ticken);
        };

        const stoppAnimation = () => {
          if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
        };

        const start = () => {
          if (laufend) return;
          laufend = true;
          startZeit = performance.now();
          startBtn.disabled = true;
          stoppBtn.disabled = false;
          rundeBtn.disabled = false;
          msg.textContent = 'Die Uhr läuft.';
          stoppAnimation();
          rafId = requestAnimationFrame(ticken);
        };

        const stopp = () => {
          if (!laufend) return;
          angesammelt = verstrichen();
          laufend = false;
          stoppAnimation();
          anzeigen();
          startBtn.disabled = false;
          stoppBtn.disabled = true;
          rundeBtn.disabled = true;
          msg.textContent = 'Angehalten – mit Start geht es weiter.';
        };

        const runde = () => {
          if (!laufend) return;
          if (rundenListe.childElementCount >= MAX_RUNDEN) {
            msg.textContent = `Maximal ${MAX_RUNDEN} Runden – bitte zurücksetzen.`;
            return;
          }
          const gesamt = verstrichen();
          const rundenzeit = gesamt - letzteRunde;
          letzteRunde = gesamt;
          rundenNr += 1;

          const li = document.createElement('li');
          li.className = 'flex items-center justify-between gap-3 bg-white px-3 py-2 text-sm';
          const label = document.createElement('span');
          label.className = 'font-medium text-zinc-600';
          label.textContent = `Runde ${rundenNr}`;
          const werte = document.createElement('span');
          werte.className = 'flex items-baseline gap-3 font-mono tabular-nums text-zinc-900';
          const rundeSpan = document.createElement('span');
          rundeSpan.textContent = formatieren(rundenzeit);
          const gesamtSpan = document.createElement('span');
          gesamtSpan.className = 'text-xs text-zinc-400';
          gesamtSpan.textContent = formatieren(gesamt);
          werte.appendChild(rundeSpan);
          werte.appendChild(gesamtSpan);
          li.appendChild(label);
          li.appendChild(werte);
          // Neueste Runde oben einfügen.
          rundenListe.insertBefore(li, rundenListe.firstChild);
          rundenBox.classList.remove('hidden');
          msg.textContent = `Runde ${rundenNr} festgehalten.`;
        };

        const reset = () => {
          laufend = false;
          stoppAnimation();
          angesammelt = 0;
          startZeit = 0;
          letzteRunde = 0;
          rundenNr = 0;
          rundenListe.innerHTML = '';
          rundenBox.classList.add('hidden');
          anzeige.textContent = formatieren(0);
          startBtn.disabled = false;
          stoppBtn.disabled = true;
          rundeBtn.disabled = true;
          msg.textContent = 'Zurückgesetzt. Bereit für eine neue Messung.';
        };

        startBtn.addEventListener('click', start);
        stoppBtn.addEventListener('click', stopp);
        rundeBtn.addEventListener('click', runde);
        resetBtn.addEventListener('click', reset);

        // Beim Verlassen der Seite die Animation sauber beenden.
        window.addEventListener('pagehide', stoppAnimation);

        reset();
      }
    }
  </script>
</BaseLayout>
