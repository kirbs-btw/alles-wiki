---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getGenerator } from '../../lib/generators';
import { getCategory } from '../../lib/categories';
import { getTool } from '../../lib/registry';
import { generatorLd, breadcrumbLd, faqLd } from '../../lib/schema';

const gen = getGenerator('fantasy-namensgenerator')!;
const cat = getCategory(gen.category)!;
const path = `/generator/${gen.slug}`;

const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Generatoren', href: '/generator' },
  { name: gen.title, href: path },
];

const relatedTools = (gen.related ?? [])
  .map((slug) => getTool(slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));

const ld: object[] = [
  generatorLd({ title: gen.title, description: gen.description, path }),
  breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href }))),
  faqLd(gen.faq),
];
---

<BaseLayout title={gen.title} description={gen.description} path={path} jsonLd={ld}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumbs items={crumbs} />

    <header class="mt-4">
      <p class="text-sm font-semibold text-brand-700">{cat.name} · Generator</p>
      <h1 class="mt-1 text-3xl font-extrabold tracking-tight text-zinc-900">{gen.title}</h1>
      <p class="mt-2 text-lg text-zinc-600">{gen.description}</p>
    </header>

    <!-- Widget -->
    <section class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm" data-gen>
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Stil</span>
          <select
            id="fng-style"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2.5 text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          >
            <option value="elbisch">Wohlklingend / elbisch</option>
            <option value="duester">Düster</option>
            <option value="drollig">Drollig</option>
          </select>
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-zinc-700">Anzahl</span>
          <input
            id="fng-count"
            type="number"
            min="1"
            max="50"
            value="8"
            step="1"
            class="w-full rounded-lg border border-zinc-300 bg-zinc-50 px-3 py-2.5 text-sm text-zinc-900 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-brand-300"
          />
        </label>
      </div>

      <div class="mt-4">
        <button
          id="fng-gen"
          type="button"
          class="rounded-lg bg-brand-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-brand-600 focus-visible:ring-2 focus-visible:ring-brand-300"
        >Generieren</button>
      </div>

      <ul id="fng-list" class="mt-6 grid gap-2 sm:grid-cols-2" aria-live="polite"></ul>

      <p id="fng-msg" class="mt-3 text-xs text-zinc-500" aria-live="polite">Wähle einen Stil und die Anzahl, dann auf „Generieren" klicken.</p>
    </section>

    <!-- Inhalt (SEO) -->
    <section class="prose-werkbank mt-10 max-w-none">
      <p>{gen.intro}</p>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold tracking-tight text-zinc-900">Häufige Fragen</h2>
      <dl class="mt-4 space-y-4">
        {gen.faq.map((f) => (
          <div class="rounded-lg border border-zinc-200 bg-white p-4">
            <dt class="font-semibold text-zinc-900">{f.q}</dt>
            <dd class="mt-1 text-sm text-zinc-600">{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    {
      relatedTools.length > 0 && (
        <section class="mt-12 rounded-xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-bold tracking-tight text-zinc-900">Passende Rechner</h2>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {relatedTools.map((t) => (
              <a href={`/rechner/${t.slug}/`} class="block rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
                <span class="font-medium text-zinc-800">{t.shortTitle ?? t.title}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>

  <script>
    const root = document.querySelector('[data-gen]');
    if (root) {
      const styleEl = document.getElementById('fng-style') as HTMLSelectElement | null;
      const countEl = document.getElementById('fng-count') as HTMLInputElement | null;
      const listEl = document.getElementById('fng-list') as HTMLElement | null;
      const msg = document.getElementById('fng-msg') as HTMLElement | null;
      const genBtn = document.getElementById('fng-gen');

      // Silben-Arrays je Stil (Anfang / Mitte / Ende).
      const STYLES: Record<string, { start: string[]; mid: string[]; end: string[] }> = {
        elbisch: {
          start: ['ae', 'el', 'gal', 'lor', 'sil', 'thal', 'ela', 'fin', 'cele', 'nim', 'arwen', 'mira', 'eowy', 'lia'],
          mid: ['ria', 'lon', 'dor', 'mae', 'wen', 'thi', 'lae', 'nor', 'vae', 'ria', 'lia', 'mir'],
          end: ['wen', 'dil', 'riel', 'las', 'thien', 'dor', 'mir', 'wyn', 'aria', 'el', 'ion', 'lith'],
        },
        duester: {
          start: ['mor', 'gor', 'kra', 'vex', 'drak', 'nyx', 'gru', 'thar', 'zul', 'mal', 'gra', 'skar'],
          mid: ['gosh', 'dak', 'rok', 'ven', 'thul', 'gar', 'nak', 'zar', 'gor', 'rim', 'drak', 'mor'],
          end: ['oth', 'gash', 'rok', 'nar', 'doom', 'kar', 'grim', 'rax', 'ull', 'mort', 'gor', 'thak'],
        },
        drollig: {
          start: ['bobo', 'fips', 'wuse', 'knub', 'pim', 'flausch', 'mü', 'zott', 'dödel', 'plums', 'krü', 'schnu'],
          mid: ['lo', 'pi', 'wu', 'bel', 'di', 'fa', 'mo', 'pe', 'lu', 'no', 'sa', 'ti'],
          end: ['li', 'chen', 'bert', 'fuß', 'wutz', 'kopp', 'ling', 'nase', 'putz', 'dorf', 'bauch', 'pelz'],
        },
      };

      const MAX = 50;

      // Unverzerrter Zufallsindex (mit Fallback auf Math.random, falls crypto fehlt).
      const randIndex = (mod: number) => {
        if (mod <= 0) return 0;
        try {
          if (window.crypto && window.crypto.getRandomValues) {
            const limit = Math.floor(2 ** 32 / mod) * mod;
            const buf = new Uint32Array(1);
            let v: number;
            do {
              window.crypto.getRandomValues(buf);
              v = buf[0];
            } while (v >= limit);
            return v % mod;
          }
        } catch {
          /* Fallback unten */
        }
        return Math.floor(Math.random() * mod);
      };

      const pick = (arr: string[]) => arr[randIndex(arr.length)];

      const makeName = (style: { start: string[]; mid: string[]; end: string[] }) => {
        // 2-3 Silben kombinieren.
        const useMid = randIndex(2) === 0; // ~50% drei Silben
        let raw = pick(style.start);
        if (useMid) raw += pick(style.mid);
        raw += pick(style.end);
        return raw.charAt(0).toUpperCase() + raw.slice(1);
      };

      const copy = async (text: string) => {
        try {
          await navigator.clipboard.writeText(text);
          if (msg) msg.textContent = `„${text}" kopiert.`;
        } catch {
          try {
            const ta = document.createElement('textarea');
            ta.value = text;
            ta.setAttribute('readonly', '');
            ta.style.position = 'absolute';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            if (msg) msg.textContent = `„${text}" kopiert.`;
          } catch {
            if (msg) msg.textContent = 'Kopieren nicht möglich – bitte manuell markieren.';
          }
        }
      };

      const generate = () => {
        if (!styleEl || !countEl || !listEl) return;

        const style = STYLES[styleEl.value] ?? STYLES.elbisch;

        let count = parseInt(countEl.value, 10);
        if (!Number.isFinite(count) || count < 1) {
          if (msg) msg.textContent = 'Bitte eine Anzahl zwischen 1 und 50 eingeben.';
          listEl.innerHTML = '';
          return;
        }
        if (count > MAX) {
          count = MAX;
          countEl.value = String(MAX);
        }

        const names = new Set<string>();
        let attempts = 0;
        const maxAttempts = count * 50; // Schutz gegen Endlosschleife
        while (names.size < count && attempts < maxAttempts) {
          names.add(makeName(style));
          attempts++;
        }

        listEl.innerHTML = '';
        names.forEach((name) => {
          const li = document.createElement('li');
          li.className =
            'flex items-center justify-between gap-2 rounded-lg border border-zinc-200 bg-zinc-50 px-3 py-2';

          const span = document.createElement('span');
          span.className = 'font-medium text-zinc-800';
          span.textContent = name;

          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className =
            'shrink-0 rounded-md border border-zinc-300 px-2.5 py-1 text-xs font-semibold text-zinc-700 transition hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-brand-300';
          btn.textContent = 'Kopieren';
          btn.addEventListener('click', () => copy(name));

          li.appendChild(span);
          li.appendChild(btn);
          listEl.appendChild(li);
        });

        if (msg) msg.textContent = `${names.size} Name${names.size === 1 ? '' : 'n'} generiert.`;
      };

      genBtn?.addEventListener('click', generate);
      generate();
    }
  </script>
</BaseLayout>
